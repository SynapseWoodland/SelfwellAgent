# =============================================================================
# Selfwell Backend · .env.example
#   复制为 .env 后填入真实值（.env 已加入 .gitignore）
#   docker compose 会自动加载根目录 .env
# =============================================================================

# ──────────────── 通用 ────────────────
# 环境标识（dev / staging / prod）；容器内 APP_ENV 影响 log 详细度
APP_ENV=dev
LOG_LEVEL=INFO
TZ=UTC

# ──────────────── 后端服务 ────────────────
# FastAPI 监听端口（与 docker-compose.yaml ports 对齐）
BACKEND_PORT=8000
# uvicorn worker 数（生产建议 = CPU 核数）
UVICORN_WORKERS=4

# ──────────────── PostgreSQL ────────────────
# 注意：docker compose 服务名是 db，应用层用 db:5432 连；本地直连用 localhost:5432
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=selfwell
POSTGRES_USER=selfwell
POSTGRES_PASSWORD=change_me_in_dev_only
# SQLAlchemy 异步 DSN（asyncpg 驱动）
DATABASE_URL=postgresql+asyncpg://selfwell:change_me_in_dev_only@db:5432/selfwell
# Alembic 迁移用（psycopg 同步驱动） —— 注意：psycopg[binary] 需在 Phase 接入 Alembic 时一并加入 pyproject.toml
# 当前 MVP 阶段 init SQL 已覆盖全部 DDL，docker-compose.yaml 中的 alembic upgrade head 暂未启用
DATABASE_URL_SYNC=postgresql+psycopg://selfwell:change_me_in_dev_only@db:5432/selfwell

# ──────────────── Redis ────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0

# ──────────────── 对象存储（MinIO 开发 / COS 生产） ────────────────
# MinIO（开发环境）
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_dev_only
MINIO_BUCKET=selfwell
MINIO_SECURE=false

# COS（生产环境，APP_ENV=prod 时生效）
# COS_SECRET_ID=AKIDxxx
# COS_SECRET_KEY=xxx
# COS_REGION=ap-guangzhou
# COS_BUCKET=selfwell-prod

# ──────────────── LLM 4 级降级链 ────────────────
# 主：Claude Sonnet 4（多模态）
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_BASE_URL=

# 备 1：GPT-4o（多模态）
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# 备 2：Qwen VL（阿里云通义千问）
DASHSCOPE_API_KEY=sk-xxx
DASHSCOPE_MODEL=qwen-vl-max

# 备 3：DeepSeek-VL（HTTP API）
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-vl
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# LLM 通用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# 月预算（元，超 ¥700/月触发告警，见 mvp-tech-architecture.md §10.3）
LLM_MONTHLY_BUDGET_YUAN=700

# ──────────────── 微信小程序 / UnionID ────────────────
WX_MP_APPID=wx_xxx
WX_MP_SECRET=xxx

# ──────────────── 推送通道 ────────────────
# 微信订阅消息（小程序）
WX_MP_TEMPLATE_ID=xxx

# 阿里云 DirectMail（邮件兜底）
ALIYUN_DM_ACCESS_KEY_ID=xxx
ALIYUN_DM_ACCESS_KEY_SECRET=xxx
ALIYUN_DM_REGION=cn-hangzhou

# ──────────────── 安全 ────────────────
# JWT 签名密钥（生产必须用 32 字节随机串；openssl rand -hex 32 生成）
JWT_SECRET_KEY=change_me_in_dev_only_at_least_32_chars_long_xxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ──────────────── 监控 ────────────────
# Prometheus 抓取路径（与 backend /metrics 路由对齐）
PROMETHEUS_MULTIPROC_DIR=/tmp/prom_multiproc
# 是否开启 /metrics 端点（开发默认开，生产按需）
ENABLE_METRICS=true

# ──────────────── 第三方回调签名 ────────────────
# 对象存储回调签名 token
STORAGE_CALLBACK_SECRET=change_me_in_dev_only