## 六、自审检查命令

```bash
# 1. 检测 PowerShell 写文件命令（应只在临时脚本里，不应在业务脚本）
grep -rn "Set-Content\|Out-File" docs/ harness/ .cursor/rules/ .cursor/skills/ 2>&1 | grep -v ".md"

# 2. 检测未指定 -Encoding utf8 的 PowerShell 操作
grep -rEn "Set-Content|Out-File" scripts/ 2>&1 | grep -v "Encoding utf8"

# 3. 检测 CRLF 换行（应全部是 LF）
# 对所有 .md/.mdc/.py/.yaml 文件
file $(git ls-files | grep -E '\.(md|mdc|py|yaml|yml)$') | grep "CRLF"

# 4. 验证中文文档完整性（Python）
python -c "
from pathlib import Path
import sys
ROOT = Path('d:/agent-project/SelfwellAgent')
files = [
    'docs/architecture/TDS/TDS-M5-persona-chat.md',
    'harness/atdd/v2/ATDD-Journey.md',
]
for f in files:
    p = ROOT / f
    if not p.exists():
        continue
    content = p.read_text(encoding='utf-8', errors='replace')
    chinese = sum(1 for c in content if '\u4e00' <= c <= '\u9fff')
    print(f'{f}: {chinese} chinese chars')
    if chinese == 0:
        print(f'  WARNING: No Chinese characters found - possible encoding corruption')
        sys.exit(1)
"
```

