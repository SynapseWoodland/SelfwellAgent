## 四、Domain Event 实现骨架

### Publisher（Context A）

```python
# app/events/bus.py
from typing import Protocol, TypeVar
from app.core.log import logger

T = TypeVar("T")

class DomainEvent(Protocol):
    event_name: str
    aggregate_id: str
    occurred_at: datetime


class EventBus(Protocol):
    async def publish(self, event: DomainEvent) -> None: ...
    async def subscribe(self, event_type: str, handler: Callable) -> None: ...


class InMemoryEventBus:
    """生产环境用 Redis Pub/Sub 或 Kafka。"""

    def __init__(self) -> None:
        self._handlers: dict[str, list[Callable]] = {}

    async def publish(self, event: DomainEvent) -> None:
        handlers = self._handlers.get(event.event_name, [])
        logger.info(
            "domain_event_published",
            event_name=event.event_name,
            aggregate_id=event.aggregate_id,
        )
        for handler in handlers:
            try:
                await handler(event)
            except Exception:
                logger.exception(
                    "event_handler_failed",
                    event_name=event.event_name,
                    handler=handler.__name__,
                )


# 单例（在 main.py 注入）
event_bus: EventBus = InMemoryEventBus()
```

### Subscriber（Context B）

```python
# app/services/notification/handlers.py
from app.events.bus import event_bus
from app.events.user_events import UserRegisteredEvent


async def on_user_registered(event: UserRegisteredEvent) -> None:
    """发送欢迎推送。"""
    await send_welcome_push(user_id=event.aggregate_id)


def register_handlers() -> None:
    event_bus.subscribe("UserRegisteredEvent", on_user_registered)
```

