## 十二、节点契约（contracts/）

```python
# ✅ app/contracts/example.py
"""example contract."""
from app.contracts.common import NodeInput, NodeOutput


class ToolInput(NodeInput):
    """Extra fields are forbidden by parent ConfigDict(extra="forbid")."""
    query: str
    options: list[str] = []


class ToolOutput(NodeOutput):
    results: list[dict] = []
