```python
# ✅ domain/entities/user_entity.py
"""User 实体。"""
from dataclasses import dataclass, field
from uuid import UUID, uuid4
from datetime import datetime, timezone
from .value_objects import Email

@dataclass
class User:
    """User 实体，有唯一标识。"""
    id: UUID = field(default_factory=uuid4)
    name: str
    email: Email
    birthday: datetime | None = None
    avatar_url: str | None = None
    created_at: datetime = field(default_factory=lambda: datetime.now(timezone.utc))
    updated_at: datetime = field(default_factory=lambda: datetime.now(timezone.utc))

    def __eq__(self, other: object) -> bool:
        if not isinstance(other, User):
            return NotImplemented
        return self.id == other.id

    def __hash__(self) -> int:
        return hash(self.id)

    def update_profile(self, name: str | None = None, email: Email | None = None) -> None:
        """更新用户资料（业务逻辑）。"""
        if name is not None:
            self.name = name
        if email is not None:
            self.email = email
        self.updated_at = datetime.now(timezone.utc)
```

```python
# ✅ domain/aggregates/user_aggregate.py
"""User 聚合根。"""
from dataclasses import dataclass, field
from uuid import UUID, uuid4
from datetime import datetime, timezone
from ..entities.user_entity import User
from ..value_objects import Email
from ..events.user_events import UserRegisteredEvent

@dataclass
class UserAggregate:
    """User 聚合根，事务边界。"""
    _id: UUID = field(default_factory=uuid4, repr=False)
    _user: User = field(default_factory=lambda: User(name="", email=Email("")))
    _registered: bool = field(default=False, repr=False)

    @property
    def id(self) -> UUID:
        return self._id

    @property
    def user(self) -> User:
        return self._user

    def register(self, name: str, email: Email) -> UserRegisteredEvent:
        """注册用户。"""
        if self._registered:
            raise InvalidOperationError("User already registered")
        self._user.name = name
        self._user.email = email
        self._registered = True
        return UserRegisteredEvent(
            user_id=self._id,
            email=str(email),
            occurred_at=datetime.now(timezone.utc),
        )
```

#### 26.3.4 Infrastructure 层：ORM Model

```python
# ✅ infrastructure/persistence/models/user_model.py
"""SQLAlchemy ORM 模型。"""
from datetime import datetime
from uuid import UUID
from sqlalchemy import String, DateTime, func
from sqlalchemy.orm import Mapped, mapped_column
from sqlalchemy.dialects.postgresql import UUID as PG_UUID

class UserModel(Base):
    """User ORM 模型（Infrastructure 层）。"""
    __tablename__ = "users"

    id: Mapped[UUID] = mapped_column(PG_UUID(as_uuid=True), primary_key=True)
    name: Mapped[str] = mapped_column(String(50), nullable=False)
    email: Mapped[str] = mapped_column(String(255), unique=True, nullable=False)
    birthday: Mapped[datetime | None] = mapped_column(DateTime(timezone=True), nullable=True)
    avatar_url: Mapped[str | None] = mapped_column(String(500), nullable=True)
    created_at: Mapped[datetime] = mapped_column(
        DateTime(timezone=True), server_default=func.now()
    )
    updated_at: Mapped[datetime] = mapped_column(
        DateTime(timezone=True), server_default=func.now(), onupdate=func.now()
    )
```

### 26.4 Mapper 转换机制

#### 26.4.1 Mapper 放置位置

| 转换方向 | Mapper 位置 | 理由 |
|----------|-------------|------|
| API Request → Application Command | `api/mappers/` | API 层负责 |
| Application Command → Domain | `application/mappers/` | Application 层编排 |
| Domain → API Response | `application/mappers/` | Application 层负责组装 |
| Domain Entity ↔ ORM Model | `infrastructure/mappers/` | Infrastructure 层负责持久化映射 |

#### 26.4.2 Mapper 实现规范（手动 Mapper）

```python
# ✅ application/mappers/user_mapper.py
"""Application ↔ Domain 转换 Mapper。"""
from uuid import UUID
from datetime import date
from ..commands.create_user_cmd import CreateUserCommand
from ...domain.value_objects import Email
from ...domain.aggregates.user_aggregate import UserAggregate

def command_to_email(cmd: CreateUserCommand) -> Email:
    """Command → Domain Email VO。"""
    return Email(value=cmd.email)

def command_to_aggregate(cmd: CreateUserCommand) -> UserAggregate:
    """Command → Domain Aggregate。"""
    email_vo = Email(value=cmd.email)
    aggregate = UserAggregate()
    return aggregate.create(name=cmd.name, email=email_vo)

def aggregate_to_response(agg: UserAggregate) -> dict:
    """Aggregate → Response DTO 数据。"""
    return {
        "id": agg.id,
        "name": agg.user.name,
        "email": str(agg.user.email),
        "birthday": agg.user.birthday,
        "avatar_url": agg.user.avatar_url,
        "created_at": agg.user.created_at,
        "updated_at": agg.user.updated_at,
    }
```

```python
# ✅ infrastructure/mappers/user_orm_mapper.py
"""Domain ↔ ORM Model 转换 Mapper。"""
from uuid import UUID
from datetime import datetime
from ...domain.entities.user_entity import User
from ...domain.value_objects import Email
from ..models.user_model import UserModel

def orm_to_entity(model: UserModel) -> User:
    """ORM Model → Domain Entity。"""
    return User(
        id=model.id,
        name=model.name,
        email=Email(value=model.email),
        birthday=model.birthday,
        avatar_url=model.avatar_url,
        created_at=model.created_at,
        updated_at=model.updated_at,
    )

def entity_to_orm(entity: User) -> UserModel:
    """Domain Entity → ORM Model。"""
    return UserModel(
        id=entity.id,
        name=entity.name,
        email=str(entity.email),
        birthday=entity.birthday,
        avatar_url=entity.avatar_url,
        created_at=entity.created_at,
        updated_at=entity.updated_at,
    )
```

#### 26.4.3 转换流程图

```
HTTP Request (JSON)
    ↓ 【api/schemas/user/requests.py: Pydantic BaseModel】
API Request DTO
    ↓ 【application/mappers/user_mapper.py: request_to_command()】
Application Command (dataclass)
    ↓ 【application/mappers/user_mapper.py: command_to_email() + aggregate factory】
Domain Email VO + UserAggregate
    ↓ 【domain/aggregates/user_aggregate.py: 业务逻辑 + 产生 Domain Event】
UserAggregate (with Event)
    ↓ 【infrastructure/persistence/repositories/: Repository 实现内部】
ORM Model
    ↓ 【infrastructure/mappers/user_orm_mapper.py: entity_to_orm()】
Database Row

(反向同理：DB → ORM → Entity → Command → Response DTO → HTTP Response)
```

### 26.5 Agent（LangGraph）与 DDD 集成

#### 26.5.1 Agent 作为 Domain Service

> **核心原则**：Agent（LangGraph）是 Domain Service 的一种实现形式，受 DDD 约束。

| DDD 概念 | LangGraph 对应 | 说明 |
|----------|---------------|------|
| Domain Service | Agent Graph | 编排多个领域操作 |
| Node | 单个处理节点 | 单一职责 |
| State (TypedDict) | Graph State | 携带上下文 |
| Tool | Domain Service 方法 | 原子领域操作 |
| Prompt Template | 领域知识 | 从 `prompts/` 加载 |

#### 26.5.2 Agent State 定义（TypedDict）

```python
# ✅ agents/graph/state.py
"""Agent Graph State 定义。"""
from typing import TypedDict, Required, NotRequired, Annotated
import operator

class AgentState(TypedDict):
    """Agent 状态，TypedDict 禁止用 dict。"""
    # 必需字段
    session_id: Required[str]
    user_id: Required[str]
    query: Required[str]

    # 累加字段（多节点追加）
    messages: Annotated[Required[list], operator.add]
    retrieved_context: Annotated[Required[list], operator.add]

    # 可选字段
    intent: NotRequired[str | None]
    selected_route: NotRequired[str | None]
    error: NotRequired[str | None]

    # 标量覆盖字段（单分支写入）
    current_step: NotRequired[str]
    approved: NotRequired[bool]
```

#### 26.5.3 Agent Node 规范

```python
# ✅ agents/nodes/classify_intent_node.py
"""意图分类节点。"""
from typing import TypedDict
from langchain_core.messages import AIMessage
from app.core.log import logger

async def classify_intent_node(state: AgentState, runtime) -> dict:
    """
    意图分类节点。

    Args:
        state: AgentState，包含 user_id, query, messages
        runtime: AgentRuntime，提供 stream_writer 等

    Returns:
        dict: 增量状态更新，包含 intent

    禁止：
        - 抛出领域异常（应返回 error 字段）
        - 直接返回整个 state（必须返回增量）
    """
    writer = runtime.stream_writer
    writer({"type": "thinking", "content": "正在分析用户意图..."})

    # 1. 业务逻辑（调用 Domain Service 或 Tool）
    intent = await _classify(state["query"])

    # 2. 日志记录
    logger.info(
        "intent_classified",
        user_id=state["user_id"],
        query_len=len(state["query"]),
        intent=intent,
    )

    # 3. 返回增量状态（禁止返回整个 state）
    return {
        "intent": intent,
        "messages": [AIMessage(content=f"识别到意图: {intent}")],
    }
```

#### 26.5.4 Agent 与 Domain 层交互

```python
# ✅ agents/services/agent_domain_service.py
"""Agent 领域服务封装（隔离 Agent 与 Domain）。"""
from dataclasses import dataclass
from uuid import UUID
from ...domain.aggregates.user_aggregate import UserAggregate
from ...domain.repositories.user_repository import IUserRepository

@dataclass
class AgentUserContextService:
    """Agent 调用 Domain 的封装服务。"""
    _user_repository: IUserRepository

    async def get_user_profile(self, user_id: UUID) -> UserAggregate | None:
        """获取用户画像（Tool 实现）。"""
        return await self._user_repository.find_by_id(user_id)

    async def check_user_eligibility(self, user_id: UUID) -> bool:
        """检查用户是否有资格（业务规则）。"""
        user = await self._user_repository.find_by_id(user_id)
        if not user:
            return False
        return user.is_active and user.is_verified
