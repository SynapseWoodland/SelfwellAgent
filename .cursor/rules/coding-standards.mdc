    description: str = "获取用户画像信息"
    args_schema: type[BaseModel] = GetUserProfileArgs

    _service: AgentUserContextService

    def __init__(self, service: AgentUserContextService):
        super().__init__()
        self._service = service

    async def _arun(self, user_id: str) -> str:
        user = await self._service.get_user_profile(UUID(user_id))
        if not user:
            return "User not found"
        return f"User: {user.name}, Status: {user.status}"
```

### 26.6 跨层数据对象转换规则

| 转换 | 方向 | 工具 | 位置 |
|------|------|------|------|
| JSON → Pydantic | HTTP → API | Pydantic 自动 | FastAPI |
| Pydantic → Command | API → Application | 手动 Mapper | `api/mappers/` |
| Command → Domain | Application → Domain | 手动 Mapper + Factory | `application/mappers/` |
| Domain → Response | Domain → API | 手动 Mapper | `application/mappers/` |
| Entity → ORM | Domain → Infrastructure | 手动 Mapper | `infrastructure/mappers/` |
| ORM → Entity | Infrastructure → Domain | 手动 Mapper | `infrastructure/mappers/` |

### 26.7 Entity 规范（简化版）

```python
from dataclasses import dataclass, field
from uuid import UUID, uuid4
from datetime import datetime, timezone

# ✅ Entity 必须有唯一标识 + 相等性基于 ID
@dataclass
class User:
    id: UUID = field(default_factory=uuid4)
    created_at: datetime = field(default_factory=lambda: datetime.now(timezone.utc))
    name: str
    email: str

    def __eq__(self, other: object) -> bool:
        if not isinstance(other, User):
            return NotImplemented
        return self.id == other.id

    def __hash__(self) -> int:
        return hash(self.id)
```

### 26.8 Value Object 规范（简化版）

```python
from dataclasses import dataclass

# ✅ Value Object 必须不可变（frozen=True）+ slots=True
@dataclass(frozen=True, slots=True)
class Email:
    value: str

    def __post_init__(self) -> None:
        if "@" not in self.value:
            raise ValueError(f"Invalid email: {self.value}")

# ✅ 用 @dataclass(frozen=True) 确保相等性基于值
@dataclass(frozen=True, slots=True)
class Address:
    province: str
    city: str
    district: str
    street: str
    postal_code: str | None = None
```

### 26.9 Aggregate 规范（简化版）

```python
from dataclasses import dataclass, field
from uuid import UUID, uuid4
from .entities import User
from .value_objects import Email
from .events import UserRegisteredEvent

# ✅ Aggregate Root：外部只能通过根 ID 引用
@dataclass
class UserAggregate:
    _id: UUID = field(default_factory=uuid4, repr=False)
    _user: User
    _registered: bool = field(default=False, repr=False)

    @property
    def id(self) -> UUID:
        return self._id

    def register(self, email: Email) -> UserRegisteredEvent:
        if self._registered:
            raise InvalidOperationError("User already registered")
        self._user.email = email.value
        self._registered = True
        return UserRegisteredEvent(
            user_id=self._id,
            email=email.value,
            occurred_at=datetime.now(timezone.utc),
        )

    # ✅ 受保护方法：内部业务逻辑
    def _can_unregister(self) -> bool:
        return not self._has_active_orders()
```

### 26.10 Domain Event 规范（简化版）

```python
from dataclasses import dataclass, field
from uuid import UUID
from datetime import datetime, timezone

# ✅ Domain Event：领域事件定义
@dataclass(frozen=True, slots=True)
class DomainEvent:
    occurred_at: datetime = field(
        default_factory=lambda: datetime.now(timezone.utc)
    )

@dataclass(frozen=True, slots=True)
class UserRegisteredEvent(DomainEvent):
    user_id: UUID
    email: str

@dataclass(frozen=True, slots=True)
class OrderPlacedEvent(DomainEvent):
    order_id: UUID
    user_id: UUID
    total_amount: int  # 分
    item_count: int
```

### 26.11 Repository 接口规范（简化版）

```python
# ✅ Repository 接口定义在 Domain 层（抽象）
from abc import ABC, abstractmethod
from uuid import UUID
from typing import Optional

class UserRepository(ABC):
    @abstractmethod
    async def save(self, user: User) -> None: ...

    @abstractmethod
    async def find_by_id(self, user_id: UUID) -> Optional[User]: ...

    @abstractmethod
    async def find_by_email(self, email: str) -> Optional[User]: ...

    @abstractmethod
    async def delete(self, user_id: UUID) -> None: ...
```

### 26.12 Domain Service 规范（简化版）

```python
from dataclasses import dataclass
from .aggregates import UserAggregate
from .repositories import UserRepository
from .value_objects import Email

# ✅ Domain Service：无状态，编排多个聚合/实体的操作
@dataclass
class UserRegistrationService:
    _repository: UserRepository

    async def register_user(
        self, name: str, email: str
    ) -> tuple[UserAggregate, list[DomainEvent]]:
        # 1. 业务规则校验（可能抛出领域异常）
        existing = await self._repository.find_by_email(email)
        if existing:
            raise EmailAlreadyExistsError(email)

        # 2. 创建聚合
        email_vo = Email(email)
        user = UserAggregate(name=name, email=email_vo)

        # 3. 注册事件
        event = user.register(email_vo)

        # 4. 持久化
        await self._repository.save(user)

        return user, [event]
```

### 26.13 反模式禁止

| 禁止 | 正确做法 |
|------|----------|
| Anemic Domain Model（贫血模型） | Entity/Aggregate 内含业务逻辑 |
| 跨 Aggregate 直接修改子对象 | 必须通过 Aggregate Root |
| Repository 实现放在 Domain 层 | 放在 Infrastructure 层 |
| Service 持有状态 | Domain Service 必须无状态 |
| Domain Event 含技术细节 | Event 只含领域概念 |
| Agent 直接操作 ORM | Agent 通过 Domain Service 操作 |
| Agent 内写业务规则 | 业务规则在 Domain 层 |
| Pydantic Model 作为 Domain 对象 | Domain 层用 `@dataclass` |
| API 层直接返回 ORM Model | 必须通过 Response DTO |

### 26.14 自审命令

```bash
# 检查 Entity 是否有 id 字段
grep -rn "class.*Entity" backend/app/domain/ | grep -v "id:"

# 检查 Value Object 是否有 frozen=True
grep -rn "@dataclass" backend/app/domain/value_objects/ | grep -v "frozen=True"

# 检查 Repository 实现是否在 Infrastructure 层
grep -rn "class.*Repository" backend/app/infrastructure/persistence/

# 检查 Domain Event 是否不可变
ruff check backend/app/domain/events/ --select=S301

# 检查 Agent 是否直接操作 ORM（禁止）
grep -rn "UserModel\|OrderModel" backend/app/agents/ && echo "FAIL" || echo "PASS"

# 检查 Pydantic 是否进入 Domain 层（禁止）
grep -rn "from pydantic import" backend/app/domain/ && echo "FAIL" || echo "PASS"

# 检查 Mapper 是否存在（必须有）
grep -rn "def.*_to_.*:" backend/app/*/mappers/ | head -20

# 检查 API 是否直接返回 ORM Model（禁止）
grep -rn "response_model=UserModel" backend/app/api/ && echo "FAIL" || echo "PASS"
```

