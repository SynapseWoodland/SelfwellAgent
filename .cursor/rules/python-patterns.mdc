## 二、Result 类型规范

```python
from dataclasses import dataclass
from typing import Generic, TypeVar

T = TypeVar("T")
E = TypeVar("E")

@dataclass(frozen=True, slots=True)
class Ok(Generic[T]):
    value: T

@dataclass(frozen=True, slots=True)
class Err(Generic[E]):
    error: E

Result = Ok[T] | Err[E]

# 使用 match 表达式
match result:
    case Ok(value):
        return value
    case Err(e):
        logger.warning(f"user_error: {e}")
        return fallback
```

