{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".cursor/hooks/session-inject.ps1",
        "failClosed": false
      }
    ],
    "subagentStart": [
      {
        "command": ".cursor/hooks/subagent-rules-inject.ps1",
        "failClosed": true
      }
    ],
    "beforeShellExecution": [
      {
        "command": "D:\\agent-project\\SelfwellAgent\\.cursor\\hooks\\guard-shell.cmd",
        "timeout": 5,
        "failClosed": true,
        "matcher": "(?i)(cat\\s|head\\s|tail\\s|more\\s|less\\s|sed\\s|awk\\s|perl\\s|echo\\s[^|]*>|printf\\s[^|]*>|\\btee\\s|rm\\s-rf|cmd\\s/c|powershell\\s-Command|Get-Content|Set-Content\\s.*-[Vv]alue|Out-File\\s|git\\s+checkout\\s+--|powershell\\s-File\\s)"
      }
    ],
    "stop": [
      {
        "command": ".cursor/hooks/audit-violations.ps1",
        "failClosed": false
      }
    ]
  }
}
