# =============================================================================
# Selfwell Backend · .env.example
#   复制为 .env 后填入真实值（.env 已加入 .gitignore）
#   docker compose 会自动加载根目录 .env
# =============================================================================

# ──────────────── 通用 ────────────────
# 环境标识（dev / staging / prod）；容器内 APP_ENV 影响 log 详细度
# 同时驱动 CORS 策略（ADR-0018）：dev/staging 全开 *，prod 读 CORS_ORIGINS 白名单 + 空则 fail-fast
APP_ENV=dev
LOG_LEVEL=INFO
TZ=UTC

# ──────────────── CORS（ADR-0018）────────────
# APP_ENV=prod 时必填；dev/staging 留空即可（默认全开）
# 逗号分隔多个 origin，不含尾斜杠，不含通配符
# 示例（prod）：CORS_ORIGINS=https://app.selfwell.cn,https://admin.selfwell.cn
CORS_ORIGINS=

# ──────────────── 后端服务 ────────────────
# FastAPI 监听端口（与 docker-compose.yaml ports 对齐）
#
# ⚠️ 本地 dev 走 Caddy 时改为 8001（让出 8000 给 Caddy 反代）
# 详见 infra/caddy/README.md §2 端口规划。
# 默认仍是 8000（与 docker-compose.yaml、backend/Dockerfile 一致），
# 适合裸跑 / 生产部署场景。
BACKEND_PORT=8000
# uvicorn worker 数（生产建议 = CPU 核数）
UVICORN_WORKERS=4

# ──────────────── PostgreSQL ────────────────
# 当前开发模式 = 宿主机跑 uvicorn + Docker 起基础设施
# - 容器侧（docker compose 网络内）：db:5432 / redis:6379 / minio:9000
# - 宿主机侧（Windows 本地）：localhost:54321 / localhost:6379 / localhost:9000
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=selfwell
POSTGRES_USER=selfwell
POSTGRES_PASSWORD=change_me_in_dev_only
# SQLAlchemy 异步 DSN（asyncpg 驱动）—— 走宿主机端口 54321
DATABASE_URL=postgresql+asyncpg://selfwell:change_me_in_dev_only@localhost:5433/selfwell
# Alembic 迁移用（psycopg 同步驱动）—— 同步走宿主机端口 54321
# 当前 MVP 阶段 init SQL 已覆盖全部 DDL，docker-compose.yaml 中的 alembic upgrade head 暂未启用
DATABASE_URL_SYNC=postgresql+psycopg://selfwell:change_me_in_dev_only@localhost:5433/selfwell

# ──────────────── Redis ────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

# ──────────────── 对象存储（MinIO 开发 / COS 生产） ────────────────
# MinIO（开发环境）
STORAGE_PROVIDER=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_dev_only
MINIO_BUCKET=selfwell
MINIO_SECURE=false
# MinIO 公网访问地址（方舟 LLM 调用 presigned URL 时需要能访问）。
# 开发环境：内网穿透地址（如 ngrok/cloudflared tunnel，格式如 https://xxx.ts.net/api/v1）
# 生产环境：MinIO 公网 LB/CNAME 或 nginx/Caddy 反向代理地址
MINIO_PUBLIC_HOST=https://husenlin.tail61999e.ts.net

# COS（生产环境，APP_ENV=prod 时生效）
# COS_SECRET_ID=AKIDxxx
# COS_SECRET_KEY=xxx
# COS_REGION=ap-guangzhou
# COS_BUCKET=selfwell-prod

# ──────────────── LLM 主备────────────────
# 主：多模态大预言模型
MULTI_API_KEY=ark-8589187e-d711-47ab-a111-05773577da86-f7fcd
MULTI_MODEL=doubao-seedream-5.0-lite
MULTI_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3/images

# 备：多模态大预言模型
BACKUP_MULTI_API_KEY=ark-8589187e-d711-47ab-a111-05773577da86-f7fcd
BACKUP_MULTI_MODEL=doubao-seedream-5.0-lite
BACKUP_MULTI_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3/images

# 主：文本大语言模型
API_KEY=ark-8589187e-d711-47ab-a111-05773577da86-f7fcd
MODEL=glm-5.2
BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# 备：文本大语言模型
BACKUP_API_KEY=ark-8589187e-d711-47ab-a111-05773577da86-f7fcd
BACKUP_MODEL=deepseek-v4-flash
BACKUP_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3

# LLM 通用参数
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048
# 月预算（元，超 ¥700/月触发告警，见 mvp-tech-architecture.md §10.3）
LLM_MONTHLY_BUDGET_YUAN=700

# ──────────────── 微信小程序 / UnionID ────────────────
WX_MP_APPID=wx9967b7cc83336b6f
WX_MP_SECRET=1d9a64c197493cc7d2026d570c87054d

# ──────────────── 推送通道 ────────────────
# 微信订阅消息（小程序）
WX_MP_TEMPLATE_ID=pIeEIAW9ZXR0EOfgSYUDf1LQ5zsYVMOUwU6gPQPEilU
WX_MP_TEMPLATE_KEYWORDS=打卡时间|打卡名称|任务说明|提醒时间

# 阿里云 DirectMail（邮件兜底）
ALIYUN_DM_ACCESS_KEY_ID=xxx
ALIYUN_DM_ACCESS_KEY_SECRET=xxx
ALIYUN_DM_REGION=cn-hangzhou

# ──────────────── 安全 ────────────────
# JWT 签名密钥（生产必须用 32 字节随机串；openssl rand -hex 32 生成）
JWT_SECRET_KEY=change_me_in_dev_only_at_least_32_chars_long_xxxxxxxxxxxxx
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ──────────────── 监控 ────────────────
# Prometheus 抓取路径（与 backend /metrics 路由对齐）
PROMETHEUS_MULTIPROC_DIR=/tmp/prom_multiproc
# 是否开启 /metrics 端点（开发默认开，生产按需）
ENABLE_METRICS=true

# ──────────────── 第三方回调签名 ────────────────
# 对象存储回调签名 token
STORAGE_CALLBACK_SECRET=change_me_in_dev_only
