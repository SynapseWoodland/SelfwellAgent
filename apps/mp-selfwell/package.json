{
  "name": "mp-selfwell",
  "version": "1.0.0",
  "description": "Selfwell 自愈 · 微信小程序前端",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run tests/contract",
    "test:all": "vitest run tests/",
    "visual:baseline": "playwright test tests/visual-baseline --project=chromium",
    "visual:baseline:install": "playwright install chromium",
    "visual:update": "playwright test tests/visual-baseline --project=chromium --update-snapshots"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.19.43",
    "@vitest/coverage-v8": "^2.1.8",
    "playwright": "^1.61.1",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.8.0",
      "onFail": "download"
    }
  }
}