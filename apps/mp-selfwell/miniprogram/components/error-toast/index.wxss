.toast {
  position: fixed;
  left: 50%;
  bottom: 240rpx;
  transform: translateX(-50%);
  padding: 24rpx 48rpx;
  border-radius: 24rpx;
  background-color: #FAFBFC;
  color: #2D3436;
  font-size: 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  z-index: 1000;
  max-width: 80%;
  text-align: center;
}

.toast--info {
  background-color: #A8C5B5;
  color: #FFFFFF;
}

.toast--warn {
  background-color: #E8B87A;
  color: #2D3436;
}

.toast--error {
  background-color: #F0D9C4;
  color: #2D3436;
}

.toast-text {
  font-size: inherit;
  color: inherit;
  word-break: break-word;
}