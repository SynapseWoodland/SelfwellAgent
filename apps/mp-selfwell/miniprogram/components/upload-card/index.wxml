<!--
  upload-card：智能分析上传卡（与 assistant-home 内联块结构 1:1 对齐）
  数据来源：assistant-home 的 ChatTurn.attachment.kind === 'upload_card'
  - title       顶部标题
  - slots       3 个虚线占位槽 [{label, filled}]
  - ageRanges   4 个年龄段 chip [{value, label, selected}]
  - submitText  按钮文案（可选，默认"上传，开始分析"）
  事件：slotTap {index} / ageChipTap {age} / startTap
-->
<view class="upload-card">
  <view class="upload-card-title">{{title}}</view>

  <view class="upload-grid">
    <view
      wx:for="{{slots}}"
      wx:key="label"
      wx:for-item="slot"
      class="upload-slot {{slot.filled ? 'upload-slot-filled' : ''}}"
      data-idx="{{index}}"
      bindtap="onSlotTap"
    >
      <!-- filled 状态优先渲染预览图：<image> 放在最前，icon/label 用 wx:elif 隐藏 -->
      <block wx:if="{{slot.filled && slot.filledUrl}}">
        <image
          class="upload-slot-preview"
          src="{{slot.filledUrl}}"
          mode="aspectFill"
          data-test="upload-slot-preview"
        />
      </block>
      <block wx:else>
        <view class="upload-slot-icon">+</view>
        <view class="upload-slot-label">{{slot.label}}</view>
      </block>
      <view wx:if="{{slot.filled && slot.filledUrl}}" class="upload-slot-badge">已上传</view>
    </view>
  </view>

  <view class="profile-section">
    <view class="profile-label">年龄段（可选）</view>
    <view class="profile-options">
      <view
        wx:for="{{ageRanges}}"
        wx:key="value"
        wx:for-item="age"
        class="profile-option {{age.selected ? 'profile-option-selected' : ''}}"
        data-value="{{age.value}}"
        bindtap="onAgeChipTap"
      >
        {{age.label}}
      </view>
    </view>
  </view>

  <button class="upload-btn-start" bindtap="onStartTap">
    {{submitText || '上传，开始分析'}}
  </button>
</view>