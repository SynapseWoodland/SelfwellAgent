<!-- greeting -->
<view wx:if="{{state === 'greeting'}}" class="bubble bubble-greeting">
  <view wx:if="{{title}}" class="bubble-title">{{title}}</view>
  <view class="bubble-text">{{text}}</view>
</view>

<!-- listening (用户输入) -->
<view wx:elif="{{state === 'listening'}}" class="bubble bubble-listening">
  <view class="bubble-text">{{text}}</view>
</view>

<!-- thinking -->
<view wx:elif="{{state === 'thinking'}}" class="bubble bubble-thinking">
  <view class="thinking-dots">
    <view class="dot" wx:for="{{dots}}" wx:key="*this"></view>
  </view>
</view>

<!-- answer (AI 答复) -->
<view wx:elif="{{state === 'answer'}}" class="bubble bubble-answer">
  <view class="bubble-text">{{text}}</view>
</view>

<!-- medical_guarded (医疗相关，温柔拒绝) -->
<view wx:elif="{{state === 'medical_guarded'}}" class="bubble bubble-answer bubble-medical">
  <view class="bubble-text">{{text}}</view>
</view>

<!-- upload (智能分析 - 上传卡内嵌气泡) -->
<view wx:elif="{{state === 'upload'}}" class="bubble bubble-answer bubble-attachment">
  <view class="bubble-text">{{text}}</view>
  <slot name="upload-card"></slot>
</view>

<!-- analyzing (智能分析 - 进度卡内嵌气泡) -->
<view wx:elif="{{state === 'analyzing'}}" class="bubble bubble-answer bubble-attachment">
  <view class="bubble-text">{{text}}</view>
  <slot name="progress-card"></slot>
</view>

<!-- report (智能分析 - 报告卡内嵌气泡) -->
<view wx:elif="{{state === 'report'}}" class="bubble bubble-answer bubble-attachment">
  <view class="bubble-text">{{text}}</view>
  <slot name="report-card"></slot>
</view>