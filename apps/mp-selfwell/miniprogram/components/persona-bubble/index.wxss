.bubble {
  margin: 16rpx;
  padding: 24rpx 32rpx;
  border-radius: 24rpx;
  max-width: 80%;
  word-break: break-word;
  font-size: 28rpx;
  line-height: 1.6;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.bubble-greeting,
.bubble-answer {
  background-color: #FFFFFF;
  color: #2D3436;
  align-self: flex-start;
  border-bottom-left-radius: 4rpx;
}

.bubble-listening {
  background-color: #A8C5B5;
  color: #FFFFFF;
  align-self: flex-end;
  border-bottom-right-radius: 4rpx;
}

.bubble-thinking {
  background-color: #FAFBFC;
  align-self: flex-start;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
}

.bubble-medical {
  border: 2rpx solid #F0D9C4;
  background-color: #FFFFFF;
}

/* 附件型气泡（upload / analyzing / report）：最大宽度撑满，便于卡片渲染 */
.bubble-attachment {
  max-width: 92%;
  padding: 24rpx 28rpx;
}

.bubble-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.bubble-text {
  white-space: pre-wrap;
  margin-bottom: 12rpx;
}

/* 让 slot 内嵌的卡片有自己的内边距（避免与 bubble padding 重复） */
.bubble-attachment .bubble-text:last-child {
  margin-bottom: 0;
}

.thinking-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #A8C5B5;
  animation: bounce 1.2s infinite ease-in-out;
}

.dot:nth-child(2) {
  animation-delay: 0.15s;
}

.dot:nth-child(3) {
  animation-delay: 0.3s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.6;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}