/* ─────────────────────────────────────────────────────
 * task-card 样式（PR-A4-b 还原）
 * v2 重构：打卡与视频解耦
 * ─────────────────────────────────────────────────────
 * Token 真源：app.wxss §13 / §17（PR-6 锁定）
 *   --mint:     #A8C5B5
 *   --ink-500:  #718096
 *   --ink-300:  #A0AEC0
 *   --ink-100:  #E2E8F0
 *   --ink-900:  #2D3436
 */

.task-card {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #E2E8F0;
}

.task-card:last-child {
  border-bottom: none;
}

.task-card.is-disabled {
  opacity: 0.5;
  pointer-events: none;
}

/* 勾选区域（v2 新增） */
.task-checkbox {
  padding: 12rpx;
  flex-shrink: 0;
}

.task-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 4rpx solid #E2E8F0;
  margin-right: 12rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-circle.is-done {
  background-color: #A8C5B5;
  border-color: #A8C5B5;
}

.task-check {
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.task-content {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 32rpx;
  color: #2D3436;
  font-weight: 500;
  line-height: 1.4;
}

.task-title.is-done {
  color: var(--color-text-weak, #A0AEC0);
  text-decoration: line-through;
}

.task-subtitle {
  margin-top: 4rpx;
  font-size: 24rpx;
  color: #718096;
}

.task-action {
  min-width: 80rpx;
  font-size: 26rpx;
  color: var(--color-primary-mint, #A8C5B5);
  font-weight: 500;
  text-align: center;
  cursor: pointer;
  flex-shrink: 0;
}

.task-action.is-done {
  color: var(--color-text-weak, #A0AEC0);
  font-weight: 400;
  text-decoration: none;
}
