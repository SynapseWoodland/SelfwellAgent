<!--
  progress-card：智能分析进度卡（与 assistant-home 内联块结构 1:1 对齐）
  数据来源：assistant-home 的 ChatTurn.attachment.kind === 'progress_card'
  - title     顶部标题
  - percent   进度 0-100（整数显示）
  - steps     3 步骤 [{label, done, current}]
  事件：无（纯展示，由父组件驱动 setData）
-->
<view class="progress-card">
  <view class="progress-card-title">{{title}}</view>

  <view class="progress-bar">
    <view
      class="progress-fill"
      style="width: {{percent}}%;"
    ></view>
  </view>
  <view class="progress-percent">{{percentText}}%</view>

  <view class="progress-steps">
    <text
      wx:for="{{steps}}"
      wx:key="label"
      wx:for-item="step"
      class="progress-step {{step.done ? 'progress-step-done' : ''}} {{step.current ? 'progress-step-current' : ''}}"
    >
      {{step.done ? '✓' : (step.current ? '▸' : '○')}} {{step.label}}
    </text>
  </view>
</view>