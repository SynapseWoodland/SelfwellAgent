<!--
  report-card：智能分析报告卡（与 assistant-home 内联块结构 1:1 对齐）
  数据来源：assistant-home 的 ChatTurn.attachment.kind === 'report_card'
  - avatarText    头像占位文字
  - name          用户昵称
  - directions    改善方向数组 [{num, title, level, description}]
  - ctaText       CTA 按钮文案（可选，默认"开始 21 天"）
  事件：ctaTap
-->
<view class="report-card">
  <view class="report-card-header">
    <view class="report-card-avatar">{{avatarText}}</view>
    <view class="report-card-text">
      <text class="report-card-name">{{name}}</text>
      <text>，这是你的 {{directions.length}} 个改善方向</text>
    </view>
  </view>

  <view
    wx:for="{{directions}}"
    wx:key="num"
    wx:for-item="dir"
    class="direction-item"
  >
    <view class="direction-head">
      <view class="direction-num">{{dir.num}}</view>
      <view class="direction-title">{{dir.title}}</view>
      <view
        class="direction-level"
        data-level="{{dir.level}}"
      >{{dir.level}}</view>
    </view>
    <view class="direction-desc">{{dir.description}}</view>
  </view>

  <button class="btn-start21" bindtap="onCtaTap">
    {{ctaText || '开始 21 天'}}
  </button>
</view>