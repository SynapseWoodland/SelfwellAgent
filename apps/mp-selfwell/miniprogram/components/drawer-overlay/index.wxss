/* =================================================================
 * PR-V2-A · drawer-overlay 组件
 * 真源：docs/design/figma-pixso-spec/pages-v2/15c-manage-drawer.html
 * AC-5: drawer 宽度 80% / max-width 320px（对齐 15c 原型）
 * AC-6: mask rgba(0,0,0,0.4)
 * AC-7: 抽屉头部米色渐变
 * ================================================================= */

.drawer-wrapper {
  position: fixed;
  inset: 0;
  z-index: 999;
}

/* ── 全屏遮罩 ─── */
.drawer-mask {
  position: absolute;
  inset: 0;
  background-color: rgba(0, 0, 0, 0.4);
}

/* ── 右侧抽屉 ─── */
.drawer {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 80%;
  max-width: 320px;
  background-color: #FFFFFF;
  border-radius: 16px 0 0 16px;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ── 抽屉头部（米色渐变）─── */
.drawer-header {
  padding: 16px 16px 12px;
  background: linear-gradient(135deg, #F5E6D3 0%, #FAF0E6 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.drawer-title {
  font-size: 15px;
  font-weight: 500;
  color: #2D3436;
}

.drawer-close {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background-color: rgba(0, 0, 0, 0.06);
  color: #2D3436;
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ── 内容插槽 ─── */
.drawer-content {
  flex: 1;
  overflow-y: auto;
  padding: 8px 0;
}

/* ── peekTab 提示条 ─── */
.drawer-peek-tab {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-top: 1px solid #F0F2F5;
  background-color: #FFFFFF;
  flex-shrink: 0;
}

.drawer-peek-tab text {
  font-size: 13px;
  color: #718096;
}
