/* PR-V2-A · drawer-overlay WXSS */
/* AC-7: 抽屉头部米色渐变（使用 token） */
/* AC-6: mask 背景 rgba(0,0,0,0.4) */
.drawer-wrapper {
  position: fixed;
  inset: 0;
  z-index: 1000;
}

.drawer-mask {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  opacity: 0;
  transition: opacity 0.3s;
}

.drawer-mask.show {
  opacity: 1;
}

/* AC-5: drawer 宽度 78% / max-width 295px */
.drawer {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  width: 78%;
  max-width: 295px;
  background: var(--bg-card);
  display: flex;
  flex-direction: column;
  transform: translateX(100%);
  transition: transform 0.3s ease;
}

.drawer.show {
  transform: translateX(0);
}

/* AC-7: drawer-header 米色渐变 */
.drawer-header {
  padding: 24rpx 32rpx;
  background: linear-gradient(135deg, var(--color-secondary-cream) 0%, var(--bg-card) 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.drawer-title {
  font-size: var(--font-size-title);
  color: var(--ink-900);
  font-weight: 600;
}

.drawer-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: var(--ink-500);
  border-radius: var(--radius-circle);
}

.drawer-body {
  flex: 1;
  overflow-y: auto;
  padding: 24rpx 32rpx;
}

.drawer-peek-tab {
  height: 120rpx;
}
