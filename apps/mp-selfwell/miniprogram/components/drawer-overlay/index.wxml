<!--
  PR-V2-A · drawer-overlay 组件
  真源：docs/design/figma-pixso-spec/pages-v2/15c-manage-drawer.html
-->
<view class="drawer-wrapper" wx:if="{{visible}}">
  <!-- 全屏遮罩 -->
  <view
    class="drawer-mask is-visible"
    bindtap="onMaskTap"
  ></view>

  <!-- 右侧抽屉 -->
  <view class="drawer is-open">
    <!-- 抽屉头部 -->
    <view class="drawer-header">
      <view class="drawer-title">{{title}}</view>
      <view class="drawer-close" bindtap="onCloseTap">✕</view>
    </view>

    <!-- 内容插槽（默认 slot） -->
    <view class="drawer-content">
      <slot />
    </view>

    <!-- peekTab 提示条 -->
    <view wx:if="{{peekTab}}" class="drawer-peek-tab">
      <text>继续探索 ›</text>
    </view>
  </view>
</view>
