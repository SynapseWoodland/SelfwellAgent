<!-- day-strip-5state 组件
  PR-V2-A P1.2
  5 态：completed / today / missed / future / feedback
-->
<view class="day-strip {{compact ? 'day-strip--compact' : ''}}">
  <view
    wx:for="{{days}}"
    wx:key="index"
    class="day-strip-item state-{{item.state}} {{activeIndex === index ? 'is-active' : ''}}"
    data-state="{{item.state}}"
    data-index="{{index}}"
    bindtap="onSelect"
  >
    <text class="day-number">{{item.dayNumber}}</text>
    <!-- 今日外发光 dot -->
    <view wx:if="{{item.state === 'today'}}" class="day-today-dot"></view>
  </view>
</view>
