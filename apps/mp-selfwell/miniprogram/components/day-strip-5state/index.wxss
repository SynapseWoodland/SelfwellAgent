/* day-strip-5state WXSS
  PR-V2-A P1.2
  Token：styles/v2-tokens.wxss
  AC 来源：day-strip-5state-component.test.ts AC-3~AC-6
*/
.day-strip {
  display: flex;
  gap: 6rpx;
  padding: 16rpx 0;
  overflow-x: auto;
}

.day-strip--compact {
  gap: 4rpx;
  padding: 8rpx 0;
}

.day-strip-item {
  position: relative;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  box-sizing: border-box;
}

/* 5 态配色（属性选择器，对齐 v2-tokens.wxss --color-state-*) */
.day-strip-item[data-state='completed'] {
  background-color: var(--color-state-completed);
  color: var(--color-bg-card);
}

.day-strip-item[data-state='today'] {
  background-color: var(--color-state-today);
  color: var(--color-primary-mint-dark);
  border: 3rpx solid var(--color-state-today-border);
}

.day-strip-item[data-state='missed'] {
  background-color: var(--color-state-missed);
  color: var(--color-text-muted);
}

.day-strip-item[data-state='future'] {
  background-color: var(--color-state-future);
  color: var(--color-text-weak);
  border: 2rpx dashed var(--color-state-future-border);
}

.day-strip-item[data-state='feedback'] {
  background-color: var(--color-state-feedback);
  color: var(--color-text-primary);
}

.day-number {
  font-size: 18rpx;
  line-height: 1;
}

/* today 外发光 dot */
.day-today-dot {
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background-color: var(--color-primary-mint);
}

/* active 高亮态 */
.is-active {
  box-shadow: 0 0 0 4rpx rgba(168, 197, 181, 0.25);
}
