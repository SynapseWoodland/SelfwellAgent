.uploader {
  width: 480rpx;
  height: 480rpx;
  border-radius: 32rpx;
  border: 4rpx dashed #A8C5B5;
  background-color: #FAFBFC;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  overflow: hidden;
}

.uploader.is-disabled {
  opacity: 0.5;
  pointer-events: none;
}

.uploader-preview {
  width: 100%;
  height: 100%;
}

.uploader-plus {
  font-size: 96rpx;
  color: #A8C5B5;
  font-weight: 200;
  line-height: 1;
}

.uploader-label {
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #4A5568;
}

.uploader.is-loading {
  opacity: 0.7;
}