<view class="ring-wrap" style="width: {{size}}rpx; height: {{size}}rpx;">
  <svg
    class="ring-svg"
    width="{{size}}rpx"
    height="{{size}}rpx"
    viewBox="0 0 {{size}} {{size}}"
  >
    <circle
      class="ring-bg"
      cx="{{size / 2}}"
      cy="{{size / 2}}"
      r="{{radius}}"
      stroke-width="{{strokeWidth}}rpx"
    />
    <circle
      class="ring-fg"
      cx="{{size / 2}}"
      cy="{{size / 2}}"
      r="{{radius}}"
      stroke-width="{{strokeWidth}}rpx"
      stroke-dasharray="{{circumference}}"
      stroke-dashoffset="{{dashOffset}}"
      stroke-linecap="round"
    />
  </svg>
  <view class="ring-text">
    <view class="ring-label">{{label}}</view>
    <view class="ring-sub">{{subLabel}}</view>
  </view>
</view>