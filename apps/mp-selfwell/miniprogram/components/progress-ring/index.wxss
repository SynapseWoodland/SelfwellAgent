/* ─────────────────────────────────────────────────────────
 * progress-ring WXSS
 * PR-V2-A P1.1 · 对齐 styles/v2-tokens.wxss
 *
 * Token（styles/v2-tokens.wxss）：
 *   --ring-size-sm: 60px / --ring-size-md: 90px / --ring-size-lg: 160px
 *   --ring-stroke: 6px / --ring-stroke-lg: 8px
 *   --ring-fg: #A8C5B5
 *   --ring-bg: #E2E8F0
 * ───────────────────────────────────────────────────────── */

.ring-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

/* ── SVG stroke 方式（兼容旧版）────────────────────────── */
.ring-svg {
  transform: rotate(-90deg);
}

.ring-bg {
  fill: none;
  stroke: var(--ring-bg, #E2E8F0);
}

.ring-fg {
  fill: none;
  stroke: var(--ring-fg, #A8C5B5);
  transition: stroke-dashoffset 480ms cubic-bezier(0.16, 1, 0.3, 1);
}

.ring-fg-gradient {
  fill: none;
  stroke: url(#ring-grad);
  transition: stroke-dashoffset 480ms cubic-bezier(0.16, 1, 0.3, 1);
}

/* ── conic-gradient 备选说明 ────────────────────────────
 * 注意：微信小程序不支持 CSS conic-gradient。
 * 若未来需要渐变圆环，用 SVG linearGradient 实现（如 .ring-fg-gradient）。
 * ──────────────────────────────────────────────────── */

/* ── 中心文字（两种方式共用）──────────────────────────── */
.ring-text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.ring-label {
  font-weight: 600;
  color: var(--color-text-primary, #2D3436);
  line-height: 1;
}

.ring-sub {
  margin-top: 4px;
  color: var(--color-text-muted, #718096);
  line-height: 1.2;
}
