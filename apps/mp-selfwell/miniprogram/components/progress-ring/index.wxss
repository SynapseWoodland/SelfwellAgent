/* ─────────────────────────────────────────────────────
 * 进度环样式（PR-A4-b 还原）
 * ─────────────────────────────────────────────────────
 * Token 真源：app.wxss §13 / §17（PR-6 锁定）
 *   --progress-ring-fg:  #A8C5B5（前景：已完成）
 *   --progress-ring-bg:  #E2E8F0（背景：未完成）
 *
 * 颜色说明：本组件样式表的 hardcoded 色码与 app.wxss token 同源；
 * 若 PR-7 迁移到 token 引用，需通过 vitest（home-tab2.test / profile-new.test）
 * 验证视觉不退。
 */

.ring-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.ring-svg {
  transform: rotate(-90deg);
}

.ring-bg {
  fill: none;
  stroke: #E2E8F0;
}

.ring-fg {
  fill: none;
  stroke: #A8C5B5;
  transition: stroke-dashoffset 480ms cubic-bezier(0.16, 1, 0.3, 1);
}

.ring-text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.ring-label {
  font-size: 56rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1;
}

.ring-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #718096;
}
