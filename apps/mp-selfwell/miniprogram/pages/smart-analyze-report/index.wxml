<!--
  IA-REF: docs/design/ia-and-wireframe.md §4.3 P03c 智能分析报告
  FIGMA  : docs/design/figma-pixso-spec/pages/06-butler-analyze-report.html
-->
<view class="report">
  <persona-bubble
    state="answer"
    title="{{reportTitle}}"
    text="{{summary}}"
    use-report-slot="{{true}}"
  >
    <view slot="report-card" class="report-card">
      <view wx:for="{{directions}}" wx:key="index" class="direction-item">
        <view class="direction-head">
          <view class="direction-num">{{item.index}}</view>
          <view class="direction-title">{{item.title}}</view>
          <view class="direction-level {{item.level}}">{{item.levelLabel}}</view>
        </view>
        <view class="direction-desc">{{item.description}}</view>
        <view class="direction-frequency">{{item.frequency}}</view>
      </view>
    </view>
  </persona-bubble>

  <view class="report-cta">
    <button class="report-btn" bindtap="onStartPlan">{{start21Label}}</button>
  </view>
</view>
