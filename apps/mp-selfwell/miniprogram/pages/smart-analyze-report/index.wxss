/* PR-A4：A 场景报告页样式 */

.report {
  display: flex;
  flex-direction: column;
  padding: 24rpx 0 200rpx;
  min-height: 100vh;
  background-color: #FAFBFC;
}

.report-card {
  margin-top: 12rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.direction-item + .direction-item {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #F0F2F5;
}

.direction-head {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.direction-num {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background-color: #A8C5B5;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.direction-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 500;
  color: #2D3436;
}

.direction-level {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background-color: #F5E6D3;
  color: #718096;
}

.direction-level.light {
  background-color: #E5F0E7;
  color: #4F6E54;
}

.direction-level.mid {
  background-color: #FDF1DE;
  color: #946D2C;
}

.direction-level.heavy {
  background-color: #FCE6E0;
  color: #B0533A;
}

.direction-desc {
  margin-top: 12rpx;
  margin-left: 48rpx;
  font-size: 26rpx;
  color: #4A5568;
  line-height: 1.6;
}

.direction-frequency {
  margin-top: 8rpx;
  margin-left: 48rpx;
  font-size: 22rpx;
  color: #718096;
}

/* 底部 CTA */
.report-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx 48rpx;
  background-color: #FFFFFF;
  border-top: 2rpx solid #F0F2F5;
}

.report-btn {
  width: 100%;
  height: 88rpx;
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(168, 197, 181, 0.4);
}
