/* feedback-diary/index.wxss
  PR-V2-C · 对齐 15a-butler-home-tab1.html 心情日记入口
  心情emoji选择 · 照片上传（可选）· 文字记录
*/
page { background: var(--color-bg-page, #FAFBFC); }

.diary-page {
  min-height: 100vh;
  background: var(--color-bg-page, #FAFBFC);
  display: flex;
  flex-direction: column;
}

/* Nav Bar */
.nav-bar {
  height: 44px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-page, #FAFBFC);
  border-bottom: 1px solid var(--color-border, #E2E8F0);
  flex-shrink: 0;
}
.nav-back { font-size: 28px; }
.nav-title { font-size: 17px; font-weight: 500; color: var(--color-text-primary, #2D3436); }
.nav-space { width: 32px; }

/* Scroll area */
.diary-scroll { flex: 1; padding: 0 16px; }

/* 日期标签 */
.diary-date {
  padding: 12px 0 8px;
  font-size: 13px;
  color: var(--color-text-muted, #718096);
  font-weight: 500;
}

/* Section label */
.section-label {
  font-size: 13px;
  color: var(--color-text-muted, #718096);
  font-weight: 500;
  margin-bottom: 10px;
}

/* ── 心情选择（emoji grid）──────────────── */
.mood-section { margin-bottom: 20px; }

.mood-grid {
  display: flex;
  gap: 10px;
}

.mood-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 4px;
  border-radius: 12px;
  background: var(--color-bg-card, #FFFFFF);
  border: 2px solid var(--color-border, #E2E8F0);
  cursor: pointer;
  transition: border-color 0.15s;
}

.mood-item.is-selected {
  border-color: var(--color-primary-mint, #A8C5B5);
  background: #E0F0E5;
}

.mood-emoji { font-size: 24px; }

.mood-label {
  font-size: 10px;
  color: var(--color-text-muted, #718096);
}

.mood-item.is-selected .mood-label {
  color: var(--color-primary-mint-dark, #5A8270);
  font-weight: 500;
}

/* ── 照片上传 ────────────────────────── */
.photo-section { margin-bottom: 16px; }

.photo-row { display: flex; gap: 10px; }

.photo-slot {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  border: 1.5px dashed var(--color-border, #CBD5E0);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  cursor: pointer;
}

.photo-icon { font-size: 24px; }
.photo-hint { font-size: 9px; color: var(--color-text-weak, #A0AEC0); }

.photo-preview {
  width: 80px;
  height: 80px;
  border-radius: 12px;
  overflow: hidden;
  position: relative;
  cursor: pointer;
}

.photo-img { width: 100%; height: 100%; }
.photo-repick {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 9px;
  text-align: center;
  padding: 2px;
}

/* ── 文字记录卡片 ────────────────────── */
.diary-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 16px;
  padding: 16px;
  box-shadow: var(--shadow-card);
  margin-bottom: 16px;
}

.diary-title {
  font-size: 15px;
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 10px;
}

.diary-input {
  width: 100%;
  min-height: 120px;
  border: none;
  background: transparent;
  font-size: 14px;
  color: var(--color-text-primary, #2D3436);
  line-height: 1.6;
  resize: none;
}

.diary-char-count {
  text-align: right;
  font-size: 11px;
  color: var(--color-text-weak, #A0AEC0);
  margin-top: 4px;
}

/* ── ACK 气泡 ──────────────────────── */
.diary-ack-wrap {
  padding: 0 0 16px;
}

.diary-ack-tip {
  font-size: 10px;
  color: var(--color-text-weak, #A0AEC0);
  text-align: center;
  margin-top: 4px;
}

.diary-bottom-space { height: 20px; }

/* ── 底部提交栏 ─────────────────────── */
.diary-submit-bar {
  padding: 12px 16px 20px;
  background: var(--color-bg-card, #FFFFFF);
  border-top: 1px solid var(--color-border, #E2E8F0);
  flex-shrink: 0;
}

.btn-submit {
  width: 100%;
  height: 46px;
  border: none;
  border-radius: 23px;
  background: var(--color-primary-mint, #A8C5B5);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 500;
}

.btn-disabled {
  background: var(--color-border, #E2E8F0);
  color: var(--color-text-weak, #A0AEC0);
}
