.plan {
  min-height: 100vh;
  padding: 32rpx;
  background-color: #FAFBFC;
}

.plan-hero {
  padding: 32rpx;
  background: linear-gradient(180deg, #B8D4E3 0%, #FAFBFC 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
}

.plan-title {
  font-size: 40rpx;
  font-weight: 500;
  color: #2D3436;
}

.plan-sub {
  margin-top: 8rpx;
  font-size: 28rpx;
  color: #4A5568;
}

.plan-calendar {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.plan-day {
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FAFBFC;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #718096;
}

.plan-day.is-done {
  background-color: #A8C5B5;
  color: #FFFFFF;
}

.plan-day.is-current {
  outline: 4rpx solid #E8B87A;
}

.plan-phases {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.plan-phase {
  padding: 16rpx 0;
  border-bottom: 2rpx solid #E2E8F0;
}

.plan-phase:last-child {
  border-bottom: none;
}

.plan-phase-range {
  font-size: 24rpx;
  color: #A8C5B5;
  font-weight: 500;
}

.plan-phase-title {
  margin-top: 4rpx;
  font-size: 32rpx;
  color: #2D3436;
  font-weight: 500;
}

.plan-phase-desc {
  margin-top: 4rpx;
  font-size: 26rpx;
  color: #718096;
}