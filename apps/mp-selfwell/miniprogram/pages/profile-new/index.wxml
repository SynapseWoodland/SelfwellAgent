<!--
  PR-3 commit-1 · profile-new 主页（V2 11-profile.html）
  ─────────────────────────────────────────────────────────────────
  真源：docs/design/figma-pixso-spec/pages/11-profile.html
  布局：头像渐变（mint → sky）+ 昵称 + streak + 6 列表项 + 底部"领取抱抱卡"CTA
-->
<view class="profile-new">
  <!-- 头像渐变区 -->
  <view class="profile-new-header">
    <view class="profile-new-avatar" data-test="avatar">
      <text>{{nickname[0] || '我'}}</text>
    </view>
    <view class="profile-new-nickname">{{nickname}}</view>
    <view class="profile-new-streak">已坚持 {{streak}} 天</view>
  </view>

  <!-- 进度环 -->
  <view class="profile-new-progress">
    <progress-ring
      percent="{{percent}}"
      size="{{160}}"
      label="{{streak}}"
      sub-label="天"
    />
  </view>

  <!-- 6 列表项 -->
  <view class="profile-new-list">
    <view
      wx:for="{{settings}}"
      wx:key="id"
      class="profile-new-row"
      data-id="{{item.id}}"
      bindtap="onTapSetting"
      data-test="profile-new-row-{{item.id}}"
    >
      <text class="profile-new-row-label">{{item.label}}</text>
      <view class="profile-new-row-right">
        <text wx:if="{{item.rightLabel}}" class="profile-new-row-summary">{{item.rightLabel}}</text>
        <text class="profile-new-row-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 领取抱抱卡 CTA -->
  <view class="profile-new-cta">
    <view class="profile-new-cta-btn" bindtap="onGotoShare">领取抱抱卡 ›</view>
  </view>
</view>