<!--
  profile-new/index.wxml
  1:1 复刻修复方案：上绿下白两段式布局
  - Nav Bar：白底 + 黑标题 + 齿轮按钮
  - 绿底区：Hi 问候语 + 3 个 chips 在问候语下方 + 左侧头像 🌿 + 年龄标签
  - 白底区：我的勋章（4 卡片网格）+ 设置区（4 项带副标题）
-->
<!-- 抽屉（保持不变）-->
<drawer-overlay
  visible="{{drawerVisible}}"
  title="更多功能"
  bind:close="onCloseDrawer"
>
  <view class="drawer-menu">
    <view
      wx:for="{{drawerItems}}"
      wx:key="id"
      class="drawer-menu-item"
      data-id="{{item.id}}"
      bindtap="onDrawerNav"
    >
      <text class="drawer-menu-label">{{item.label}}</text>
      <text class="drawer-menu-arrow">›</text>
    </view>
  </view>
</drawer-overlay>

<!-- 页面主体（白底）-->
<view class="profile-page">

  <!-- Nav Bar：白底 + 黑标题 + 齿轮按钮 -->
  <view class="profile-nav">
    <view class="profile-nav-title">我的</view>
    <view class="profile-nav-icon" bindtap="onOpenDrawer">⚙️</view>
  </view>

  <!-- 上半：绿底区域 -->
  <view class="profile-green-zone">
    <!-- 问候语 -->
    <view class="profile-greeting">Hi, {{nickname || '用户'}}</view>

    <!-- 用户标签（问候语下方，独占一行）-->
    <view class="chips-row">
      <view class="chip">{{ageRange || '25-30 岁'}}</view>
      <view class="chip">{{crowd || '久坐人群'}}</view>
      <view class="chip">{{level || '自律 C'}}</view>
    </view>

    <!-- 头像 + 年龄标签行 -->
    <view class="profile-main-row">
      <!-- 左侧：🌿 叶子头像 -->
      <view class="profile-avatar">🌿</view>

      <!-- 右侧：年龄标签 -->
      <view class="profile-tags">
        <text class="profile-tag-text">{{ageRange || '25-30 岁'}}</text>
      </view>
    </view>
  </view>

  <!-- 下半：白底区域 -->
  <view class="profile-white-zone">

    <!-- 我的勋章区 -->
    <view class="medals-section">
      <view class="section-header">
        <text class="section-title">我的勋章</text>
        <text class="section-link">查看全部 ›</text>
      </view>
      <view class="medals-grid">
        <view class="medal-card">
          <text class="medal-icon">📷</text>
          <text class="medal-label">记录相册</text>
        </view>
        <view class="medal-card">
          <text class="medal-icon">🎁</text>
          <text class="medal-label">我的卡片</text>
        </view>
        <view class="medal-card">
          <text class="medal-icon">⏰</text>
          <text class="medal-label">我的时光</text>
        </view>
        <view class="medal-card">
          <text class="medal-icon">📖</text>
          <text class="medal-label">自我档案</text>
        </view>
      </view>
    </view>

    <!-- 设置区：4 项带副标题 + 彩色方块图标 -->
    <view class="settings-section">
      <view class="settings-row" bindtap="onTapSettings" data-id="notification">
        <view class="settings-icon-wrap" style="background:#FFCC80;">
          <text>🔔</text>
        </view>
        <view class="settings-content">
          <text class="settings-label">通知设置</text>
          <text class="settings-sub">打卡提醒 · 抱抱卡发放</text>
        </view>
        <text class="settings-arrow">›</text>
      </view>

      <view class="settings-row" bindtap="onTapSettings" data-id="privacy">
        <view class="settings-icon-wrap" style="background:#CE93D8;">
          <text>🔒</text>
        </view>
        <view class="settings-content">
          <text class="settings-label">隐私政策</text>
          <text class="settings-sub">数据权限</text>
        </view>
        <text class="settings-arrow">›</text>
      </view>

      <view class="settings-row" bindtap="onTapSettings" data-id="about">
        <view class="settings-icon-wrap" style="background:#FFF9C4;">
          <text>ℹ️</text>
        </view>
        <view class="settings-content">
          <text class="settings-label">关于自愈</text>
          <text class="settings-sub">产品介绍</text>
        </view>
        <text class="settings-arrow">›</text>
      </view>

      <view class="settings-row settings-row--last" bindtap="onTapSettings" data-id="contact">
        <view class="settings-icon-wrap" style="background:#A5D6A7;">
          <text>💬</text>
        </view>
        <view class="settings-content">
          <text class="settings-label">联系客服</text>
          <text class="settings-sub">在线反馈</text>
        </view>
        <text class="settings-arrow">›</text>
      </view>
    </view>

  </view>

  <view class="profile-bottom-spacer"></view>
</view>
