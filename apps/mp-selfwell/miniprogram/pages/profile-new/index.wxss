/* =================================================================
 * profile-new/index.wxss
 * 1:1 复刻修复方案：上绿下白两段式布局
 * - Nav Bar：白底 + 黑标题 + 齿轮按钮
 * - 绿底区：Hi 问候语 + 3 个 chips + 左侧头像 🌿 + 年龄标签
 * - 白底区：我的勋章（4 卡片网格）+ 设置区（4 项带副标题）
 * ================================================================= */

/* ─── 页面容器（白底）─── */
.profile-page {
  min-height: 100vh;
  background-color: #FFFFFF;
}

/* ─── Nav Bar（白底 + 黑标题 + 齿轮）─── */
.profile-nav {
  height: 44px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background-color: #FFFFFF;
  position: sticky;
  top: 0;
  z-index: 100;
}

.profile-nav-title {
  font-size: 17px;
  font-weight: 600;
  color: #000000;
}

.profile-nav-icon {
  font-size: 20px;
  color: #555555;
  padding: 4px 8px;
}

/* ─── 上半：绿底区域 ─── */
.profile-green-zone {
  background-color: #E8F5E9;
  padding: 16px 16px 20px;
}

/* 问候语 */
.profile-greeting {
  font-size: 22px;
  font-weight: 600;
  color: #1A1A1A;
  margin-bottom: 6px;
}

/* chips 行（在问候语下方） */
.chips-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 6px;
  margin-bottom: 12px;
}

/* chip 胶囊 */
.chip {
  background: rgba(255, 255, 255, 0.6);
  border-radius: 10px;
  padding: 3px 10px;
  font-size: 12px;
  color: #555555;
}

/* 头像 + 标签行 */
.profile-main-row {
  display: flex;
  align-items: center;
  margin-top: 12px;
}

/* 头像：白底圆形 + 🌿 */
.profile-avatar {
  width: 56px;
  height: 56px;
  border-radius: 28px;
  background-color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  line-height: 1;
  margin-right: 12px;
}

/* 标签区域 */
.profile-tags {
  display: flex;
  flex-direction: column;
}

.profile-tag-text {
  font-size: 12px;
  color: #555555;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 10px;
  padding: 3px 10px;
}

/* ─── 下半：白底区域 ─── */
.profile-white-zone {
  background-color: #FFFFFF;
  padding: 0 0 16px;
}

/* ─── 勋章区 ─── */
.medals-section {
  padding: 16px;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #1A1A1A;
}

.section-link {
  font-size: 13px;
  color: #888888;
}

/* 勋章 4 卡片网格 */
.medals-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10px;
}

.medal-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 12px 8px;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
}

.medal-icon {
  font-size: 24px;
  margin-bottom: 4px;
}

.medal-label {
  font-size: 11px;
  color: #555555;
  text-align: center;
}

/* ─── 设置区 ─── */
.settings-section {
  margin: 0 16px;
}

/* 设置每行 */
.settings-row {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #F0F0F0;
}

.settings-row--last {
  border-bottom: none;
}

/* 图标容器（彩色圆角方块）*/
.settings-icon-wrap {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  margin-right: 12px;
  flex-shrink: 0;
}

/* 设置内容区 */
.settings-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.settings-label {
  font-size: 15px;
  color: #212121;
}

.settings-sub {
  font-size: 12px;
  color: #9E9E9E;
  margin-top: 2px;
}

/* 箭头 */
.settings-arrow {
  font-size: 16px;
  color: #BDBDBD;
  margin-left: 8px;
}

/* ─── 底部留白（tabbar 高度）─── */
.profile-bottom-spacer {
  height: 80px;
}

/* ─── 抽屉内菜单 ─── */
.drawer-menu {
  display: flex;
  flex-direction: column;
  background: #FFFFFF;
  border-radius: 16px;
  overflow: hidden;
}

.drawer-menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 16px;
  border-bottom: 1px solid #F0F0F0;
}

.drawer-menu-item:last-child {
  border-bottom: none;
}

.drawer-menu-label {
  font-size: 15px;
  color: #212121;
}

.drawer-menu-arrow {
  font-size: 14px;
  color: #BDBDBD;
}
