<!--
  profile-edit 子页 · V5.2.1-PR5.1 (edit) + V2-PR5 (read mode)
  - 6 字段档案表单（edit 模式）
  - intensity / skinType 必填校验
  - onSubmitProfile 调 utils/request.post('/users/profile') + 加 submitting 防抖
  - PR-5 扩展：mode=read 时渲染只读视图（6 字段 + 标签 chips + 21 天小档案 + [编辑] CTA）

  关键约束（frontend-standards §WXSS class 命名）：
  - 业务字段值（如 intensity='轻柔'）是中文 → class 名禁止拼接中文
  - 用 [data-value='轻柔'] 属性选择器（见 index.wxss）
-->
<view class="profile-edit">
  <!-- ── PR-5 · read mode 视图 ── -->
  <block wx:if="{{mode === 'read'}}">
    <view class="profile-edit-banner">
      <text class="profile-edit-banner-text">已完善 {{profileFilledCount}}/6 项档案</text>
    </view>

    <!-- 6 字段只读摘要 -->
    <view class="pe-read-card" data-test="pe-read-card-summary">
      <view class="pe-read-row">
        <text class="pe-read-label">年龄段</text>
        <text class="pe-read-value">{{ageRange || '未填'}}</text>
      </view>
      <view class="pe-read-row">
        <text class="pe-read-label">每日久坐</text>
        <text class="pe-read-value">{{sittingHours || '未填'}} 小时</text>
      </view>
      <view class="pe-read-row">
        <text class="pe-read-label">重点关注部位</text>
        <text class="pe-read-value">{{focusParts.length ? focusParts.join('、') : '未填'}}</text>
      </view>
      <view class="pe-read-row">
        <text class="pe-read-label">干预强度</text>
        <text class="pe-read-value">{{intensity || '未填'}}</text>
      </view>
      <view class="pe-read-row">
        <text class="pe-read-label">偏好干预时段</text>
        <text class="pe-read-value">{{preferredTime || '未填'}}</text>
      </view>
      <view class="pe-read-row">
        <text class="pe-read-label">肤质</text>
        <text class="pe-read-value">{{skinType || '未填'}}</text>
      </view>
    </view>

    <!-- tag chip 区（从 archive.tags 拉：body_part / concern / lifestyle / intensity） -->
    <view class="pe-read-card" data-test="pe-read-card-tags">
      <view class="pe-read-section-title">我的标签</view>
      <block wx:if="{{archiveSummary}}">
        <view wx:if="{{archiveSummary.tags.body_part.length}}" class="pe-read-tag-row">
          <text class="pe-read-tag-cat">部位</text>
          <view class="pe-read-tag-chips">
            <text wx:for="{{archiveSummary.tags.body_part}}" wx:key="*this" class="pe-chip pe-chip-selected">{{item}}</text>
          </view>
        </view>
        <view wx:if="{{archiveSummary.tags.concern.length}}" class="pe-read-tag-row">
          <text class="pe-read-tag-cat">关注</text>
          <view class="pe-read-tag-chips">
            <text wx:for="{{archiveSummary.tags.concern}}" wx:key="*this" class="pe-chip pe-chip-selected">{{item}}</text>
          </view>
        </view>
        <view wx:if="{{archiveSummary.tags.lifestyle.length}}" class="pe-read-tag-row">
          <text class="pe-read-tag-cat">作息</text>
          <view class="pe-read-tag-chips">
            <text wx:for="{{archiveSummary.tags.lifestyle}}" wx:key="*this" class="pe-chip pe-chip-selected">{{item}}</text>
          </view>
        </view>
        <view wx:if="{{archiveSummary.tags.intensity.length}}" class="pe-read-tag-row">
          <text class="pe-read-tag-cat">强度</text>
          <view class="pe-read-tag-chips">
            <text wx:for="{{archiveSummary.tags.intensity}}" wx:key="*this" class="pe-chip pe-chip-selected">{{item}}</text>
          </view>
        </view>
      </block>
      <view wx:elif="{{archiveLoading}}" class="pe-read-loading">
        <text>标签加载中…</text>
      </view>
      <view wx:elif="{{archiveError}}" class="pe-read-error">
        <text>{{archiveError}}</text>
      </view>
      <view wx:else class="pe-read-empty">
        <text>暂无标签</text>
      </view>
    </view>

    <!-- 21 天小档案（从 archive 拉 plan + checkin） -->
    <view class="pe-read-card" data-test="pe-read-card-archive">
      <view class="pe-read-section-title">21 天小档案</view>

      <view wx:if="{{archiveLoading}}" class="pe-read-loading">
        <text>档案加载中…</text>
      </view>

      <block wx:elif="{{archiveSummary}}">
        <view wx:if="{{archiveSummary.plan}}" class="pe-read-archive-block">
          <view class="pe-read-archive-num">{{archiveSummary.plan.current_day}}/{{archiveSummary.plan.total_days}}</view>
          <view class="pe-read-archive-stage">{{archiveSummary.plan.stage}}</view>
        </view>
        <view wx:else class="pe-read-archive-block">
          <view class="pe-read-archive-num">尚未开启方案</view>
          <view class="pe-read-archive-stage">在智能管家发起一次诊断即可生成</view>
        </view>

        <view class="pe-read-stat-row">
          <view class="pe-read-stat">
            <text class="pe-read-stat-num">{{archiveSummary.checkin.total}}</text>
            <text class="pe-read-stat-label">累计打卡</text>
          </view>
          <view class="pe-read-stat">
            <text class="pe-read-stat-num">{{archiveSummary.checkin.streak_days}}</text>
            <text class="pe-read-stat-label">连续天数</text>
          </view>
        </view>
      </block>

      <view wx:elif="{{archiveError}}" class="pe-read-error">
        <text>{{archiveError}}</text>
      </view>
    </view>

    <!-- PR-5 · read mode 底部 [编辑] CTA -->
    <button
      class="profile-submit-btn"
      bindtap="onTapEditMode"
      data-test="pe-read-edit-cta"
    >
      编辑档案
    </button>
  </block>

  <!-- ── PR-5 · edit mode 视图（向前兼容原 PR5 行为） ── -->
  <block wx:else>
    <view class="profile-edit-banner">
      <text class="profile-edit-banner-text">已完善 {{profileFilledCount}}/6 项档案</text>
    </view>

    <!-- 年龄段 -->
    <view class="profile-field">
      <view class="profile-field-label">年龄段</view>
      <view class="profile-field-options">
        <view
          wx:for="{{ageRangeOptions}}"
          wx:key="value"
          class="profile-chip {{ageRange === item.value ? 'profile-chip-selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectAgeRange"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 久坐小时数 -->
    <view class="profile-field">
      <view class="profile-field-label">每日久坐小时数</view>
      <input
        class="profile-field-input profile-field-input-large"
        type="number"
        maxlength="2"
        placeholder="0-24"
        value="{{sittingHours}}"
        bindinput="onInputSittingHours"
        bindblur="onBlurSittingHours"
      />
      <text wx:if="{{sittingHoursError}}" class="profile-field-error">{{sittingHoursError}}</text>
    </view>

    <!-- 重点关注部位（多选） -->
    <view class="profile-field">
      <view class="profile-field-label">重点关注部位（可多选）</view>
      <view class="profile-field-options">
        <view
          wx:for="{{focusPartOptions}}"
          wx:key="value"
          class="profile-chip {{focusPartsSelected[item.value] ? 'profile-chip-selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="onToggleFocusPart"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 干预强度（必填） -->
    <view class="profile-field">
      <view class="profile-field-label">
        干预强度
        <text class="profile-required">*</text>
      </view>
      <view class="profile-field-options">
        <view
          wx:for="{{intensityOptions}}"
          wx:key="value"
          class="profile-chip {{intensity === item.value ? 'profile-chip-selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectIntensity"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 偏好干预时段 -->
    <view class="profile-field">
      <view class="profile-field-label">偏好干预时段</view>
      <view class="profile-field-options">
        <view
          wx:for="{{preferredTimeOptions}}"
          wx:key="value"
          class="profile-chip {{preferredTime === item.value ? 'profile-chip-selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectPreferredTime"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- 肤质（必填） -->
    <view class="profile-field">
      <view class="profile-field-label">
        肤质
        <text class="profile-required">*</text>
      </view>
      <view class="profile-field-options">
        <view
          wx:for="{{skinTypeOptions}}"
          wx:key="value"
          class="profile-chip {{skinType === item.value ? 'profile-chip-selected' : ''}}"
          data-value="{{item.value}}"
          bindtap="onSelectSkinType"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- FR-4 · submitting 锁：disabled + 切换文案 -->
    <button
      class="profile-submit-btn {{submitting ? 'profile-submit-btn-disabled' : ''}}"
      bindtap="onSubmitProfile"
      disabled="{{submitting}}"
    >
      {{submitting ? '同步中…' : '保存档案'}}
    </button>
  </block>
</view>