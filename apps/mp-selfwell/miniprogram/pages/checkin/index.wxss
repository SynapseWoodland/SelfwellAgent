.checkin {
  min-height: 100vh;
  padding: 48rpx;
  background-color: #FAFBFC;
}

.checkin-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #2D3436;
}

.checkin-desc {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 32rpx;
}

.checkin-items {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 16rpx 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.checkin-item {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #E2E8F0;
}

.checkin-item:last-child {
  border-bottom: none;
}

.checkin-tick {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #A0AEC0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #FFFFFF;
  background-color: transparent;
}

.checkin-item--done .checkin-tick {
  background-color: #A8C5B5;
  border-color: #A8C5B5;
}

.checkin-item--done .checkin-item-title {
  color: #A0AEC0;
  text-decoration: line-through;
}

.checkin-item-title {
  font-size: 30rpx;
  color: #2D3436;
  flex: 1;
}

.checkin-feedback {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.checkin-feedback-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.checkin-feedback-input {
  width: 100%;
  min-height: 160rpx;
  font-size: 28rpx;
  color: #2D3436;
  line-height: 1.6;
  background-color: #F5F7FA;
  border-radius: 16rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.checkin-feedback-count {
  margin-top: 8rpx;
  text-align: right;
  font-size: 22rpx;
  color: #A0AEC0;
}

.checkin-btn {
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.checkin-btn[disabled] {
  background-color: #E2E8F0;
  color: #A0AEC0;
}

.checkin-ack {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.checkin-ack-hint {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #A0AEC0;
}
