<!--
  assistant-home/index.wxml
  PR-V2-C · 对齐 15a-butler-home-tab1.html 原型
  保留 SSE chat 流 + 对齐 15a 视觉结构（day-banner/entry-cards/chips/input-area/drawer）
-->
<!-- 抽屉放在最外层，独立于 flex 容器 -->
<drawer-overlay visible="{{drawerVisible}}" title="管理页" bind:close="onCloseDrawer">
  <!-- 抽屉头部进度块 -->
  <view class="drawer-progress">
    <view class="drawer-progress-title">当前进度</view>
    <view class="drawer-progress-day">第 {{currentDay}} 天 / 21</view>
    <view class="drawer-progress-sub">已坚持 {{currentDay}} 天 · 慢慢来</view>
  </view>
  <!-- 抽屉卡片 grid（仅放入口卡之外的功能入口） -->
  <view class="drawer-grid">
    <view class="drawer-card" bindtap="onDrawerNav" data-page="home">
      <view class="drawer-card-icon" style="background:#E0F0E5;">◐</view>
      <view class="drawer-card-title">今日任务</view>
      <view class="drawer-card-sub">进度环 · 3 项动作</view>
    </view>
    <view class="drawer-card" bindtap="onDrawerNav" data-page="album">
      <view class="drawer-card-icon" style="background:#F5E6D3;">◷</view>
      <view class="drawer-card-title">我的时光</view>
      <view class="drawer-card-sub">21 天时间轴</view>
    </view>
    <view class="drawer-card" bindtap="onDrawerNav" data-page="notification-settings">
      <view class="drawer-card-icon" style="background:#F0F2F5;">⚙</view>
      <view class="drawer-card-title">通知设置</view>
      <view class="drawer-card-sub">每日早 8:00 提醒</view>
    </view>
  </view>
</drawer-overlay>

<!-- 页面主体：flex 纵向排列，底部聊天框始终固定 -->
<view class="assistant">
  <!-- Nav Bar（15a原型：白底 + 黑字 + 抽屉按钮） -->
  <view class="assistant-nav">
    <view class="assistant-nav-back" bindtap="onNavBack">‹</view>
    <view class="assistant-nav-title">智能管家</view>
    <view class="assistant-nav-more" bindtap="onOpenDrawer">⋯</view>
  </view>

  <!-- 对话流（SSE chat 气泡） -->
  <scroll-view
    class="assistant-stream"
    scroll-y
    scroll-into-view="{{lastTurnId}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view
      wx:for="{{turns}}"
      wx:key="id"
      id="{{item.id}}"
      class="assistant-turn"
    >
      <persona-bubble
        state="{{item.state}}"
        text="{{item.text || ''}}"
        title="{{item.title || ''}}"
      />
    </view>
  </scroll-view>

  <!-- Day N Banner（15a原型：第N天banner） -->
  <view class="day-banner" wx:if="{{currentDay > 0}}">
    <view class="day-pill">第 {{currentDay}} 天</view>
    <view class="day-text">{{dayEncourageText}}</view>
  </view>

  <!-- 入口卡片（15a原型） -->
  <view class="entry-cards" wx:if="{{!entryHidden}}">
    <!-- 智能分析 -->
    <view class="entry-card" bindtap="onTapEntry" data-id="smart_analyze">
      <view class="entry-icon" style="background:#F5E6D3;">◎</view>
      <view class="entry-content">
        <view class="entry-title">智能分析</view>
        <view class="entry-sub">上传 3 张照片，生成你的养护参考</view>
      </view>
      <view class="entry-action">
        <button class="btn-start">开始</button>
      </view>
    </view>
    <!-- 心情日记 -->
    <view class="entry-card" bindtap="onTapEntry" data-id="mood_diary">
      <view class="entry-icon" style="background:#F0D9C4;">✎</view>
      <view class="entry-content">
        <view class="entry-title">心情日记</view>
        <view class="entry-sub">想留下点什么吗？没有格式</view>
      </view>
      <view class="entry-action">
        <view class="entry-arrow">›</view>
      </view>
    </view>
    <!-- 问问过去的自己 -->
    <view class="entry-card" bindtap="onTapEntry" data-id="recall_self">
      <view class="entry-icon" style="background:#D4C5E2;">◷</view>
      <view class="entry-content">
        <view class="entry-title">问问过去的自己</view>
        <view class="entry-sub">好奇 7 天前的你吗？</view>
      </view>
      <view class="entry-action">
        <view class="entry-arrow">›</view>
      </view>
    </view>
  </view>

  <!-- 快速 Chips（15a原型） -->
  <view class="chips-bar">
    <view class="chip" bindtap="onTapChip" data-text="今天好累">今天好累</view>
    <view class="chip" bindtap="onTapChip" data-text="今天练完了">今天练完了</view>
    <view class="chip" bindtap="onTapChip" data-text="肩颈有点紧">肩颈有点紧</view>
    <view class="chip" bindtap="onTapChip" data-text="心情不错">心情不错</view>
  </view>

  <!-- 输入区（15a原型：cream背景） -->
  <view class="assistant-inputbar">
    <input
      class="assistant-input"
      placeholder="直接跟我说就好"
      value="{{inputText}}"
      bindinput="onInput"
      bindconfirm="onSend"
      confirm-type="send"
    />
    <view class="assistant-send" bindtap="onSend">发送</view>
  </view>
</view>
