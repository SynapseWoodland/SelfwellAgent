<!--
  PR-3 commit-2 · assistant-home V2 UI 重制（保留 _stream_smart_analyze 5 阶段消费）
  ──────────────────────────────────────────────────────────────────────
  真源：plans/v2-IA-pr-internal.md §PR-3 commit-2
  真源：docs/design/figma-pixso-spec/pages/15a-butler-home-tab1.html
  真源：plans/v2-unified-parent.md §3.3「_stream_smart_analyze 5 阶段事件序列」契约
  ──────────────────────────────────────────────────────────────────────
  关键约束：
  1) 不退：consumeAssistantStream 5 阶段 progress/report/end/start/error 消费逻辑（PR-A4+PR-2 落地）
  2) 不退：presignAndUploadOneForAssistant 调用 + image_keys/body_parts schema
  3) 仅重制：入口卡 / chips / 输入栏 / nav-bar 视觉（V2 token：mint + cream + lavender）
  4) 兼容：现有 vitest `assistant-home-smart-body.test.ts`（jest 在 miniprogram/tests/）+ PR-A4 静态契约测试不退

  V2 升版要点：
  - nav-bar 背景：mint 主色（PR-6 token --color-primary-mint）
  - nav-bar 文字 + 头像：白 + 字号适配 V2
  - entry cards：expanded 模式下 4 张卡横排，圆角 + 阴影 V2 polish
  - chips：圆角胶囊 + 主色描边（active 态）
  - input bar：底部固定，圆角 36rpx + 发送按钮 mint 主色
-->
<view class="assistant">
  <!-- V2 顶部导航（mint 主色背景 + 白字 + safe-area） -->
  <view class="assistant-nav" data-test="nav-bar">
    <view class="assistant-nav-back" bindtap="onNavBack" data-test="nav-back">‹</view>
    <view class="assistant-nav-title">智能管家</view>
    <view class="assistant-nav-actions">
      <view class="assistant-nav-btn" data-test="history-btn" bindtap="onTapHistory">历史</view>
      <view class="assistant-nav-btn" data-test="settings-btn" bindtap="onTapSettings">设置</view>
      <view class="assistant-nav-more" bindtap="onNavAction" data-test="nav-more">⋯</view>
    </view>
  </view>

  <!-- 顶部回忆气泡（Day 7/14/21 触发器；PR-3 commit-2 暂时保留 hook 占位，未来视觉确认后激活） -->
  <view wx:if="{{false}}" class="assistant-recall-bubble" data-test="recall-bubble">
    <text class="assistant-recall-text">回忆气泡</text>
  </view>

  <!-- 对话流（V2 polish：底部留白更宽，mint/cream 渐变头像） -->
  <scroll-view
    class="assistant-stream {{butlerCardsMode === 'collapsed' || butlerCardsMode === 'focused' ? 'is-collapsed' : ''}}"
    scroll-y
    scroll-into-view="{{lastTurnId}}"
    enhanced
    show-scrollbar="{{false}}"
  >
    <view
      wx:for="{{turns}}"
      wx:key="id"
      id="{{item.id}}"
      class="assistant-turn"
    >
      <persona-bubble
        state="{{item.state}}"
        text="{{item.text || ''}}"
        title="{{item.title || ''}}"
      >
        <upload-card
          wx:if="{{item.attachment && item.attachment.kind === 'upload_card'}}"
          slot="upload-card"
          title="{{item.title || '上传照片生成你的画像'}}"
          slots="{{item.attachment.slots}}"
          age-ranges="{{item.attachment.ageRanges}}"
          submit-text="上传，开始分析"
          bind:slotTap="onUploadSlotTap"
          bind:ageChipTap="onSelectAge"
          bind:startTap="onSubmitUpload"
        />

        <progress-card
          wx:if="{{item.attachment && item.attachment.kind === 'progress_card'}}"
          slot="progress-card"
          title="{{item.attachment.title || '正在为你生成画像'}}"
          percent="{{item.attachment.percent}}"
          steps="{{item.attachment.steps}}"
        />

        <report-card
          wx:if="{{item.attachment && item.attachment.kind === 'report_card'}}"
          slot="report-card"
          avatar-text="{{item.attachment.avatarText}}"
          name="{{item.attachment.name}}"
          directions="{{item.attachment.directions}}"
          cta-text="开始 21 天"
          bind:ctaTap="onStartPlan"
        />
      </persona-bubble>
    </view>

    <view wx:if="{{entryHidden && !turns.length}}" class="assistant-stream-tail"></view>
  </scroll-view>

  <!-- V2 入口卡块（与现有 butler-cards-block 组件契约不变） -->
  <butler-cards-block
    mode="{{butlerCardsMode}}"
    cards="{{entryCards}}"
    popover-open="{{popoverOpen}}"
    bind:cards-tap="onTapEntry"
    bind:floating-tap="onTapFloatingIcon"
    bind:popover-close="onPopoverClose"
  />

  <!-- V2 chips 4 项（圆角胶囊 + 主色描边 active） -->
  <view class="chips-bar" data-test="chips-bar">
    <view
      wx:for="{{chips}}"
      wx:key="id"
      class="chip {{item.active ? 'chip-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTapChip"
    >
      <block wx:if="{{item.id === 'smart_analyze'}}">🔍 智能分析</block>
      <block wx:elif="{{item.id === 'today'}}">📅 今日 · 第 {{item.dayIndex || 1}} 天</block>
      <block wx:elif="{{item.id === 'chat'}}">💬 聊聊今天</block>
      <block wx:elif="{{item.id === 'compare'}}">📊 查看对比</block>
      <block wx:else>{{item.text}}</block>
    </view>
  </view>

  <!-- V2 输入栏（圆角 36rpx + 发送按钮 mint 主色） -->
  <view class="assistant-inputbar" data-test="input-area">
    <view class="assistant-mic" data-test="mic-icon" bindtap="onTapMic">🎤</view>
    <input
      class="assistant-input"
      placeholder="直接跟我说就好"
      value="{{inputText}}"
      bindinput="onInput"
      bindfocus="onInputFocus"
      bindblur="onInputBlur"
      confirm-type="send"
      bindconfirm="onSend"
    />
    <view class="assistant-camera" data-test="camera-icon" bindtap="onTapCamera">📷</view>
    <view class="assistant-send" bindtap="onSend" data-test="send-btn">发送</view>
  </view>
</view>