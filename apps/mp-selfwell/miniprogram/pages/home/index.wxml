<!--
  pages/home/index.wxml — 今天 Tab（V2 15b-today-tab2.html）
  PR-V2-C
  真源：docs/design/figma-pixso-spec/pages-v2/15b-today-tab2.html
  Token：styles/v2-tokens.wxss
-->
<view class="home">
  <!-- ── 顶部 Nav Bar ────────────────────────────────── -->
  <view class="home-nav">
    <view class="home-nav-title">今天</view>
    <view class="home-nav-btn" bindtap="onOpenDrawer" data-test="nav-drawer-btn">
      <!-- SVG 三点图标 -->
      <svg viewBox="0 0 24 24" fill="none" width="20" height="20">
        <circle cx="5" cy="12" r="1.5" fill="#2D3436"/>
        <circle cx="12" cy="12" r="1.5" fill="#2D3436"/>
        <circle cx="19" cy="12" r="1.5" fill="#2D3436"/>
      </svg>
    </view>
  </view>

  <!-- ── 可滚动内容 ────────────────────────────────── -->
  <scroll-view class="home-scroll" scroll-y>
    <!-- P0-1: 进度区（mint 渐变背景） -->
    <view class="home-progress-section" data-test="progress-section">
      <!-- 进度环 90px（左侧） -->
      <progress-ring
        size="{{90}}"
        variant="gradient"
        percent="{{percent}}"
        label="{{done}}"
        sub-label="/ {{total}}"
      />
      <!-- 进度信息（右侧） -->
      <view class="home-progress-info">
        <view class="home-progress-greet">{{greeting}}{{nickname ? '，' + nickname : ''}}</view>
        <view class="home-progress-sub">已坚持 {{streak}} 天 · 慢慢来</view>
        <button class="home-btn-checkin" bindtap="onToggleCheckin">今日打卡</button>
      </view>
    </view>

    <!-- P0-3: plan-overview 卡片（day-strip + phase-bar + phase-label） -->
    <view class="home-plan-overview" bindtap="onGotoPlan" data-test="plan-overview">
      <view class="home-plan-overview-head">
        <view class="home-plan-overview-title">21 天方案 · 你走过 {{streak}} 天</view>
        <view class="home-plan-overview-link">查看完整方案 ›</view>
      </view>
      <!-- 21 天 day-strip（5 态） -->
      <day-strip-5state
        days="{{dayStrip}}"
        activeIndex="{{currentDayIndex}}"
        bind:select="onDayStripSelect"
      />
      <!-- phase-bar（三阶段进度条） -->
      <view class="home-phase-bar">
        <view class="home-phase-bar-p1" style="flex: {{currentDay <= 7 ? currentDay : 7}};"></view>
        <view class="home-phase-bar-p2" style="flex: {{currentDay > 7 ? (currentDay <= 14 ? currentDay - 7 : 7) : 0}};"></view>
        <view class="home-phase-bar-p3" style="flex: {{currentDay > 14 ? currentDay - 14 : 0}};"></view>
      </view>
      <!-- phase-label -->
      <view class="home-phase-label">
        <text>阶段 {{phaseIndex}} · 第 {{phaseDayStart}}-{{phaseDayEnd}} 天</text>
        <text class="home-phase-label-now">第 {{currentDay}} 天 / 阶段 {{phaseIndex}}</text>
      </view>
    </view>

    <!-- task-section（今日小动作） -->
    <view class="home-task-section" data-test="task-section">
      <view class="home-task-header">
        <text class="home-task-title">今日小动作</text>
        <text class="home-task-meta">{{done}}/{{total}} 项 · {{totalMinutes}} 分钟</text>
      </view>
      <view class="home-task-hint">不强制</view>
      <!-- task cards -->
      <view class="home-task-list">
        <task-card
          wx:for="{{taskCards}}"
          wx:key="id"
          id="{{item.id}}"
          title="{{item.title}}"
          subtitle="{{item.subtitle}}"
          done="{{item.done}}"
          video-url="{{item.videoUrl}}"
          bind:toggle="onTaskToggle"
          bind:tap="onTaskTap"
        />
      </view>
    </view>

    <!-- P1: hug-section（米色渐变抱抱卡入口） -->
    <view
      class="home-hug-section {{hugDisabled ? 'disabled' : ''}}"
      bindtap="{{hugDisabled ? '' : 'onGotoShare'}}"
      data-test="hug-section"
    >
      <view class="home-hug-title">🎁 抱抱卡 · {{hugCardSubtitle}}</view>
      <view class="home-hug-sub">第 7/14/21 天可生成专属抱抱卡</view>
    </view>

    <!-- time-section（我的时光入口） -->
    <view class="home-time-section" bindtap="onGotoTimeAlbum" data-test="time-section">
      <view class="home-time-icon">◷</view>
      <view class="home-time-content">
        <view class="home-time-title">我的时光</view>
        <view class="home-time-sub">21 天时间轴 · 看看走过的路</view>
      </view>
      <view class="home-time-arrow">›</view>
    </view>
  </scroll-view>

  <!-- ── 底部 Tab Bar 占位（由 app.json tabBar 渲染，此处占位 83px）── -->
  <view class="home-tab-bar-placeholder"></view>

  <!-- 右下角浮动抽屉按钮（FAB） -->
  <view class="home-drawer-fab" bindtap="onOpenDrawer" data-test="drawer-fab">
    <text>⋯</text>
  </view>

  <!-- P1: 打卡完成全屏遮罩（打卡完成后显示） -->
  <view
    wx:if="{{checkinComplete}}"
    class="home-complete-overlay"
    data-test="complete-overlay"
  >
    <view class="home-complete-icon">🌿</view>
    <view class="home-complete-title">今天的你，练完了</view>
    <view class="home-complete-sub">已坚持 {{streak}} 天<br/>真的棒，明天见</view>
    <button class="home-btn-checkin" bindtap="onToggleCheckin">返回</button>
  </view>

  <!-- P0-4: 抽屉（右侧滑入，用 drawer-overlay 组件） -->
  <drawer-overlay
    visible="{{drawerOpen}}"
    title="管理页"
    peek-tab="{{true}}"
    bind:close="onCloseDrawer"
  >
    <!-- 抽屉内容：管理卡片 grid -->
    <view class="home-drawer-grid">
      <view
        wx:for="{{drawerCards}}"
        wx:key="id"
        class="home-drawer-card"
        data-id="{{item.id}}"
        bindtap="onTapDrawerCard"
        data-test="drawer-card-{{item.id}}"
      >
        <view class="home-drawer-card-icon" style="background: {{item.iconBg}};">{{item.iconText}}</view>
        <view class="home-drawer-card-title">{{item.title}}</view>
        <view class="home-drawer-card-sub">{{item.subtitle}}</view>
      </view>
    </view>
    <!-- 抽屉底部进度块 -->
    <view class="home-drawer-progress">
      <view class="home-drawer-progress-label">当前进度</view>
      <view class="home-drawer-progress-num">第 {{streak}} 天 / 21</view>
      <view class="home-drawer-progress-sub">已坚持 {{streak}} 天 · 慢慢来</view>
    </view>
  </drawer-overlay>
</view>
