/* =================================================================
 * pages/home/index.wxss — 今天 Tab（V2 15b-today-tab2.html）
 * PR-V2-C
 * 真源：docs/design/figma-pixso-spec/pages-v2/15b-today-tab2.html
 * Token：styles/v2-tokens.wxss
 *
 * 关键约束：
 *  - 颜色/圆角/间距必须引用 var(--color-*) / var(--radius-*) / var(--space-*)，禁止硬编码 hex
 *  - 业务字段值不拼接 class 名；day-strip cell 用 [data-state='completed|today|missed|future|feedback']
 * ================================================================= */

@import "../../styles/v2-tokens.wxss";

/* ── Nav Bar ────────────────────────────────────────── */
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 16px;
  height: 44px;
  background-color: var(--color-bg-page, #FAFBFC);
  border-bottom: 1px solid var(--color-border, #E2E8F0);
}

.home-nav-title {
  font-size: 17px;
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}

/* ── 可滚动区域 ────────────────────────────────────── */
.home-scroll {
  height: calc(100vh - 44px - 83px); /* 扣掉 nav + tab-bar */
  overflow-y: auto;
  background-color: var(--color-bg-page, #FAFBFC);
  padding-bottom: 16px;
}

/* ── P0-1: 进度区（mint 渐变背景）────────────────── */
.home-progress-section {
  display: flex;
  align-items: center;
  gap: 18px;
  margin: 16px;
  padding: 20px;
  background: linear-gradient(135deg, #FFFFFF 0%, #FAF7F0 100%);
  border-radius: var(--radius-lg, 16px);
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}

.home-progress-info {
  flex: 1;
  min-width: 0;
}

.home-progress-greet {
  font-size: var(--font-size-heading, 18px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 4px;
}

.home-progress-sub {
  font-size: var(--font-size-body, 13px);
  color: var(--color-text-muted, #718096);
  margin-bottom: 10px;
}

.home-btn-checkin {
  display: inline-block;
  background-color: var(--color-primary-mint, #A8C5B5);
  color: #FFFFFF;
  border: none;
  border-radius: 20px;
  padding: 8px 18px;
  font-size: var(--font-size-body, 13px);
  font-weight: 500;
  line-height: 1;
}

/* ── P0-3: plan-overview 卡片 ─────────────────────── */
.home-plan-overview {
  margin: 0 16px 16px;
  padding: 16px;
  background-color: var(--color-bg-card, #FFFFFF);
  border-radius: var(--radius-lg, 16px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
}

.home-plan-overview-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.home-plan-overview-title {
  font-size: var(--font-size-body, 14px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}

.home-plan-overview-link {
  font-size: var(--font-size-body-sm, 12px);
  color: var(--color-primary-mint-dark, #5A8270);
}

/* ── 7 天紧凑 strip（PR-V2-C · 原型 15b）─────────── */
.home-day-strip-m {
  display: flex;
  gap: 3px;
  margin-bottom: 10px;
}

.home-day-strip-item-m {
  flex: 1;
  aspect-ratio: 1;
  border-radius: 5px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.home-day-strip-item-m .home-day-strip-num {
  font-weight: 600;
  font-size: 12px;
  line-height: 1;
  color: inherit;
}

.home-day-strip-item-m .home-day-strip-sub {
  font-size: 8px;
  margin-top: 2px;
  opacity: 0.85;
  line-height: 1;
  color: inherit;
}

.home-day-strip-item-m.completed {
  background-color: var(--color-state-completed, #A8C5B5);
  color: #FFFFFF;
}

.home-day-strip-item-m.today-m {
  background-color: var(--color-bg-card, #FFFFFF);
  border: 2px solid var(--color-state-today-border, #A8C5B5);
  color: var(--color-text-primary, #2D3436);
}

.home-day-strip-item-m.today-m .home-day-strip-sub {
  font-weight: 600;
}

.home-day-strip-item-m.missed {
  background-color: var(--color-state-missed, #F0F2F5);
  color: var(--color-text-weak, #A0AEC0);
}

.home-day-strip-item-m.future {
  background-color: var(--color-state-future, #FAFBFC);
  border: 1px dashed var(--color-state-future-border, #E2E8F0);
  color: var(--color-text-weak, #A0AEC0);
}

.home-day-strip-item-m.feedback {
  background-color: var(--color-state-feedback, #D4C5E2);
  color: #FFFFFF;
}

/* ── phase-bar（三阶段进度条）─────────────────────── */
.home-phase-bar {
  height: 4px;
  background-color: var(--color-border, #E2E8F0);
  border-radius: 2px;
  overflow: hidden;
  display: flex;
  margin-top: 12px;
  margin-bottom: 4px;
}

.home-phase-bar-p1 {
  background-color: var(--color-phase-1, #A8C5B5);
  transition: flex-basis 0.3s ease;
}

.home-phase-bar-p2 {
  background-color: var(--color-phase-2, #C7D8B9);
}

.home-phase-bar-p3 {
  background-color: var(--color-phase-3, #9C7AB8);
}

/* ── phase-label ─────────────────────────────────── */
.home-phase-label {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  color: var(--color-text-weak, #A0AEC0);
  margin-top: 4px;
}

.home-phase-label-now {
  color: var(--color-primary-mint-dark, #5A8270);
  font-weight: 500;
}

/* ── task-section ──────────────────────────────── */
.home-task-section {
  margin: 0 16px 16px;
}

.home-task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6px;
}

.home-task-title {
  font-size: var(--font-size-body, 16px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}

.home-task-meta {
  font-size: var(--font-size-body-sm, 12px);
  color: var(--color-text-muted, #718096);
}

.home-task-hint {
  font-size: var(--font-size-body-sm, 12px);
  color: var(--color-text-weak, #A0AEC0);
  margin-bottom: 10px;
  padding: 0 4px;
}

.home-task-list {
  background-color: var(--color-bg-card, #FFFFFF);
  border-radius: var(--radius-lg, 16px);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  padding: 16px;
}

/* ── P1: hug-section（米色渐变）───────────────────── */
.home-hug-section {
  margin: 0 16px 16px;
  padding: 16px;
  border-radius: var(--radius-lg, 16px);
  background: linear-gradient(135deg, var(--color-secondary-cream, #F5E6D3) 0%, #FFE5D0 100%);
  cursor: pointer;
}

.home-hug-section.disabled {
  background: var(--color-bg-page, #FAFBFC);
  cursor: default;
}

.home-hug-title {
  font-size: var(--font-size-body-lg, 15px);
  font-weight: 500;
  color: #6B5544;
  margin-bottom: 4px;
}

.home-hug-section.disabled .home-hug-title {
  color: var(--color-text-weak, #A0AEC0);
}

.home-hug-sub {
  font-size: var(--font-size-body-sm, 12px);
  color: var(--color-accent-earth, #A0724F);
}

.home-hug-section.disabled .home-hug-sub {
  color: var(--color-text-weak, #A0AEC0);
}

/* ── time-section ──────────────────────────────── */
.home-time-section {
  margin: 0 16px 16px;
  padding: 14px 16px;
  background-color: var(--color-bg-card, #FFFFFF);
  border-radius: var(--radius-lg, 16px);
  display: flex;
  align-items: center;
  gap: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  cursor: pointer;
}

.home-time-icon {
  width: 40px;
  height: 40px;
  border-radius: 10px;
  background-color: var(--color-secondary-cream, #F5E6D3);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}

.home-time-content {
  flex: 1;
  min-width: 0;
}

.home-time-title {
  font-size: var(--font-size-body-lg, 15px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 2px;
}

.home-time-sub {
  font-size: var(--font-size-body-sm, 12px);
  color: var(--color-text-muted, #718096);
}

.home-time-arrow {
  color: var(--color-text-weak, #A0AEC0);
  font-size: 18px;
}

/* ── Tab Bar 占位 ───────────────────────────────── */
.home-tab-bar-placeholder {
  height: 83px;
}

/* ── 右下角浮动抽屉 FAB 按钮 ───────────────────── */
.home-drawer-fab {
  position: fixed;
  right: 16px;
  bottom: 90px;
  width: 48px;
  height: 48px;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-drawer-fab-icon {
  width: 48px;
  height: 48px;
  background: linear-gradient(135deg, #A8C5B5, #94B59E);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(168, 197, 181, 0.5);
}

.home-drawer-fab-tooltip {
  position: absolute;
  bottom: 56px;
  left: 50%;
  transform: translateX(-50%);
  white-space: nowrap;
  background: rgba(0, 0, 0, 0.75);
  color: #FFFFFF;
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  opacity: 0;
  transition: opacity 0.2s;
  pointer-events: none;
}

.home-drawer-fab:active .home-drawer-fab-tooltip {
  opacity: 1;
}

/* ── P1: complete-overlay（全屏打卡完成）────────── */
.home-complete-overlay {
  position: fixed;
  inset: 0;
  z-index: 15;
  background-color: rgba(255, 255, 255, 0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px;
  text-align: center;
}

.home-complete-icon {
  font-size: 60px;
  margin-bottom: 16px;
}

.home-complete-title {
  font-size: var(--font-size-title, 22px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 8px;
}

.home-complete-sub {
  font-size: var(--font-size-body, 14px);
  color: var(--color-text-muted, #718096);
  margin-bottom: 24px;
  line-height: 1.6;
}

/* ── 抽屉内容 ──────────────────────────────────── */
.home-drawer-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 16px;
}

.home-drawer-card {
  background-color: var(--color-bg-page, #F7F8FA);
  border-radius: var(--radius-md, 12px);
  padding: 14px 12px;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
}

.home-drawer-card-icon {
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
  margin-bottom: 4px;
}

.home-drawer-card-title {
  font-size: var(--font-size-body, 14px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}

.home-drawer-card-sub {
  font-size: var(--font-size-caption, 11px);
  color: var(--color-text-weak, #A0AEC0);
}

/* ── 抽屉底部进度块 ────────────────────────────── */
.home-drawer-progress {
  margin-top: 18px;
  padding: 14px;
  background-color: var(--color-bg-page, #F7F8FA);
  border-radius: var(--radius-md, 12px);
}

.home-drawer-progress-label {
  font-size: var(--font-size-caption, 12px);
  color: var(--color-text-muted, #718096);
  margin-bottom: 4px;
}

.home-drawer-progress-num {
  font-size: var(--font-size-title, 22px);
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}

.home-drawer-progress-sub {
  font-size: var(--font-size-caption, 12px);
  color: var(--color-primary-mint, #A8C5B5);
  margin-top: 4px;
}
