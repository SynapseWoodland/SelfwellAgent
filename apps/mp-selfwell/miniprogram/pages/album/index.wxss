/* PR-5 · album 子页 */

.al-page {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding: 24rpx 0 200rpx;
}

.al-week-bar {
  white-space: nowrap;
  padding: 16rpx 32rpx;
  background-color: #FFFFFF;
  border-bottom: 2rpx solid #F0F2F5;
}

.al-week-list {
  display: inline-flex;
  gap: 16rpx;
}

.al-week-chip {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: #4A5568;
  background-color: #FAFBFC;
  border: 2rpx solid #E2E8F0;
  border-radius: 32rpx;
}

.al-week-chip-selected {
  background-color: #A8C5B5;
  border-color: #A8C5B5;
  color: #FFFFFF;
}

.al-stats {
  display: flex;
  margin: 24rpx 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.al-stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.al-stat-num {
  font-size: 40rpx;
  color: #2D3436;
  font-weight: 500;
  margin-bottom: 6rpx;
}

.al-stat-label {
  font-size: 22rpx;
  color: #718096;
}

.al-loading,
.al-error {
  text-align: center;
  padding: 96rpx 32rpx;
  color: #718096;
  font-size: 28rpx;
}

.al-empty {
  text-align: center;
  padding: 96rpx 32rpx;
}

.al-empty-icon {
  font-size: 96rpx;
  color: #E2E8F0;
  margin-bottom: 24rpx;
}

.al-empty-text {
  font-size: 30rpx;
  color: #4A5568;
  margin-bottom: 8rpx;
}

.al-empty-hint {
  font-size: 24rpx;
  color: #A0AEC0;
}

.al-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 16rpx;
}

.al-grid-cell {
  width: calc((100% - 64rpx) / 3);
  aspect-ratio: 1 / 1;
  margin: 8rpx;
  border-radius: 12rpx;
  overflow: hidden;
  background-color: #E2E8F0;
}

.al-grid-img {
  width: 100%;
  height: 100%;
  display: block;
}