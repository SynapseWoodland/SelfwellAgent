<view class="delivery-page">
  <view class="nav-bar">
    <view class="nav-back" bindtap="onNavBack">‹</view>
    <view class="nav-title">智能分析</view>
    <view class="nav-space"></view>
  </view>

  <scroll-view class="delivery-scroll" scroll-y>
    <!-- hero bounce 动画 -->
    <view class="plan-hero" bindtap="onGoToday">
      <view class="plan-hero-icon">🎉</view>
      <view class="plan-hero-title">准备好了</view>
      <view class="plan-hero-sub">你的 21 天方案已就绪</view>
    </view>

    <!-- 摘要卡 -->
    <view class="summary-card">
      <view class="summary-icon">▦</view>
      <view class="summary-info">
        <view class="summary-title">21 天 · 3 个阶段 · 45 个视频任务</view>
        <view class="summary-sub">基于 12 个标签 · 视频库 50+ 已匹配</view>
      </view>
    </view>

    <!-- 前 5 天预览 -->
    <view class="preview-section">
      <view class="section-title">前 5 天预览</view>
      <view class="day-preview-card">
        <view
          wx:for="{{visibleDays}}"
          wx:key="day"
          class="day-row {{item.phase}}"
          data-phase="{{item.phase}}"
        >
          <view class="day-num">{{item.day}}</view>
          <view class="day-info">
            <view class="day-task">{{item.title}}</view>
            <view class="day-meta">{{item.meta}}</view>
          </view>
          <view class="day-arrow">›</view>
        </view>
      </view>
      <view class="more-days">…还有 <text class="more-days-count">{{remainingDays}}</text> 天在日历里</view>
    </view>

    <!-- 阶段图例 -->
    <view class="phase-legend">
      <view class="phase-legend-item">
        <view class="phase-legend-dot p1-dot"></view>
        阶段 1（1-7 天）
      </view>
      <view class="phase-legend-item">
        <view class="phase-legend-dot p2-dot"></view>
        阶段 2（8-14 天）
      </view>
      <view class="phase-legend-item">
        <view class="phase-legend-dot p3-dot"></view>
        阶段 3（15-21 天）
      </view>
    </view>

    <!-- 提示语 -->
    <view class="plan-note">
      第 1 天从明天开始 · 你也可以从今天开始第 1 项<br />
      21 天无重复视频 · 每 7 天一张抱抱卡
    </view>
    <view class="bottom-scroll-space"></view>
  </scroll-view>

  <!-- 底部 CTA -->
  <view class="plan-cta">
    <button class="btn-primary" bindtap="onGoToday">从今天开始</button>
    <button class="btn-secondary" bindtap="onGoPlanTabs">先看完整方案 ›</button>
  </view>
</view>
