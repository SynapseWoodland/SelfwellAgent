/* plan-delivery/index.wxss
  PR-V2-C · 对齐 15h-p03c-plan-delivery.html 原型
  Token：styles/v2-tokens.wxss
*/
page {
  background: var(--color-bg-page, #FAFBFC);
}

.delivery-page {
  min-height: 100vh;
  color: var(--color-text-primary, #2D3436);
}

/* Nav Bar */
.nav-bar {
  height: 44px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--color-bg-page, #FAFBFC);
  border-bottom: 1px solid var(--color-border, #E2E8F0);
}
.nav-back {
  width: 32px;
  font-size: 28px;
}
.nav-title {
  font-size: 17px;
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
}
.nav-space {
  width: 32px;
}

/* Scroll area */
.delivery-scroll {
  height: calc(100vh - 44px - 100px);
}

/* Hero bounce 动画 */
.plan-hero {
  padding: 32px 20px 20px;
  text-align: center;
  background: linear-gradient(180deg, #FFFFFF 0%, var(--color-bg-page, #FAFBFC) 100%);
  cursor: pointer;
}

.plan-hero-icon {
  font-size: 56px;
  margin-bottom: 10px;
  animation: bounce 1.2s ease-in-out;
}
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}

.plan-hero-title {
  font-size: 22px;
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 6px;
}

.plan-hero-sub {
  font-size: 13px;
  color: var(--color-text-muted, #718096);
  line-height: 1.6;
}

/* 摘要卡 */
.summary-card {
  margin: 16px;
  padding: 14px 16px;
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  display: flex;
  align-items: center;
  gap: 12px;
}

.summary-icon {
  width: 42px;
  height: 42px;
  border-radius: 10px;
  background: linear-gradient(135deg, #A8C5B5, #94B59E);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  flex-shrink: 0;
  color: #FFFFFF;
}

.summary-info { flex: 1; }
.summary-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary, #2D3436);
  margin-bottom: 2px;
}
.summary-sub { font-size: 11px; color: var(--color-text-muted, #718096); }

/* 预览区 */
.preview-section { margin: 0 16px 12px; }
.section-title {
  font-size: 13px;
  color: var(--color-text-muted, #718096);
  margin: 0 4px 8px;
  font-weight: 500;
}

.day-preview-card {
  background: var(--color-bg-card, #FFFFFF);
  border-radius: 14px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.day-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 14px;
  border-bottom: 1px solid var(--color-border, #F0F2F5);
  cursor: pointer;
}
.day-row:last-child { border-bottom: none; }

.day-num {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: var(--color-border, #F0F2F5);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-muted, #718096);
  flex-shrink: 0;
}
.day-row.p1 .day-num { background: #E0F0E5; color: #5A8270; }
.day-row.p2 .day-num { background: #F0E8DC; color: #A0724F; }
.day-row.p3 .day-num { background: #E6DFF0; color: #9C7AB8; }

.day-info { flex: 1; min-width: 0; }
.day-task {
  font-size: 13px;
  color: var(--color-text-primary, #2D3436);
  font-weight: 500;
  margin-bottom: 2px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.day-meta { font-size: 11px; color: var(--color-text-weak, #A0AEC0); }
.day-arrow { color: var(--color-text-weak, #A0AEC0); font-size: 16px; }

/* 阶段图例 */
.phase-legend {
  margin: 0 16px 16px;
  padding: 12px 16px;
  background: #F7F8FA;
  border-radius: 12px;
  display: flex;
  gap: 14px;
}
.phase-legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  color: var(--color-text-muted, #718096);
}
.phase-legend-dot { width: 8px; height: 8px; border-radius: 50%; }
.p1-dot { background: var(--color-primary-mint, #A8C5B5); }
.p2-dot { background: var(--color-phase-2, #C7D8B9); }
.p3-dot { background: var(--color-accent-warm, #9C7AB8); }

/* more days */
.more-days {
  margin: 0 16px 16px;
  text-align: center;
  font-size: 12px;
  color: var(--color-text-weak, #A0AEC0);
  padding: 8px;
}
.more-days-count { color: var(--color-primary-mint-dark, #5A8270); font-weight: 500; }

/* 提示语 */
.plan-note {
  margin: 0 16px 12px;
  padding: 10px 12px;
  border-radius: 10px;
  background: linear-gradient(135deg, #F5E6D3 0%, #FFE5D0 100%);
  font-size: 11px;
  color: #6B5544;
  line-height: 1.6;
}

/* Bottom CTA */
.plan-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 12px 16px 20px;
  background: var(--color-bg-card, #FFFFFF);
  border-top: 1px solid var(--color-border, #E2E8F0);
}

.btn-primary {
  width: 100%;
  padding: 13px;
  border-radius: 24px;
  border: none;
  background: var(--color-primary-mint, #A8C5B5);
  color: #FFFFFF;
  font-size: 14px;
  font-weight: 500;
}

.btn-secondary {
  width: 100%;
  background: transparent;
  border: none;
  font-size: 12px;
  color: var(--color-primary-mint-dark, #5A8270);
  text-align: center;
  padding: 6px;
  font-weight: 500;
}
