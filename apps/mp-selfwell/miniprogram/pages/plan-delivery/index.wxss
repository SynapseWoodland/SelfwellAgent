page { background: var(--bg-page); }
.delivery-page { min-height: 100vh; color: var(--ink-900); }
.nav-bar { height: 44px; padding: 0 16px; display: flex; align-items: center; justify-content: space-between; background: var(--bg-page); }
.nav-back { width: 32px; font-size: 28px; }
.nav-title { font-size: 17px; font-weight: 500; }
.nav-space { width: 32px; }
.delivery-scroll { height: calc(100vh - 44px); }
.deliver-hero { padding: 26px 16px 14px; text-align: center; background: linear-gradient(180deg, #FFFFFF 0%, var(--bg-page) 100%); }
.deliver-icon { margin-bottom: 6px; font-size: 46px; animation: pop .6s ease-out; }
@keyframes pop { 0% { transform: scale(0); } 70% { transform: scale(1.08); } 100% { transform: scale(1); } }
.deliver-title { margin-bottom: 4px; font-size: 18px; font-weight: 500; }
.deliver-sub { color: var(--ink-500); font-size: 11px; }
.summary-card-m { margin: 12px 14px; padding: 10px 12px; display: flex; align-items: center; gap: 10px; border-radius: var(--radius-md); background: var(--bg-card); box-shadow: var(--shadow-card); }
.summary-icon-m { width: 36px; height: 36px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-sm); background: linear-gradient(135deg, var(--color-primary-mint), #94B59E); color: #FFFFFF; font-size: 18px; }
.summary-info-m { flex: 1; }
.summary-title-m { margin-bottom: 2px; font-size: 12px; font-weight: 500; }
.summary-sub-m { color: var(--ink-500); font-size: 10px; }
.summary-arrow { color: var(--ink-300); font-size: 18px; }
.preview-section-m { margin: 0 14px 10px; }
.preview-title-m { margin: 0 4px 6px; color: var(--ink-500); font-size: 11px; font-weight: 500; }
.preview-card-m { overflow: hidden; border-radius: var(--radius-md); background: var(--bg-card); box-shadow: var(--shadow-card); }
.day-row-m { min-height: 54px; padding: 9px 12px; display: flex; align-items: center; gap: 10px; border-bottom: 1px solid #F0F2F5; }
.day-row-m:last-child { border-bottom: 0; }
.day-num-m { width: 28px; height: 28px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border-radius: var(--radius-circle); background: #E0F0E5; color: var(--color-primary-mint-dark); font-size: 11px; font-weight: 500; }
.day-row-m[data-status='completed'] .day-num-m { background: var(--color-primary-mint); color: #FFFFFF; }
.day-row-m[data-status='active'] .day-num-m { box-sizing: border-box; border: 2px solid var(--color-primary-mint); background: #FFFFFF; color: var(--color-primary-mint-dark); }
.day-row-m[data-status='feedback'] .day-num-m { background: var(--color-secondary-lavender); color: #FFFFFF; }
.day-info-m { flex: 1; min-width: 0; }
.day-task-m { overflow: hidden; color: var(--ink-900); font-size: 12px; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
.day-meta-m { color: var(--ink-300); font-size: 10px; }
.day-arrow-m { color: var(--ink-300); font-size: 14px; }
.more-days { margin: 0 14px 12px; padding: 8px; text-align: center; color: var(--color-primary-mint-dark); font-size: 12px; }
.legend-m { margin: 0 14px 14px; padding: 10px 14px; display: flex; justify-content: space-between; border-radius: 10px; background: #F7F8FA; }
.legend-item-m { display: flex; align-items: center; gap: 5px; color: var(--ink-500); font-size: 10px; }
.legend-dot-m { width: 7px; height: 7px; border-radius: var(--radius-circle); background: var(--ink-100); }
.legend-item-m[data-status='completed'] .legend-dot-m { background: var(--color-primary-mint); }
.legend-item-m[data-status='active'] .legend-dot-m { box-sizing: border-box; border: 2px solid var(--color-primary-mint); background: #FFFFFF; }
.legend-item-m[data-status='feedback'] .legend-dot-m { background: var(--color-secondary-lavender); }
.delivery-note { margin: 0 14px 12px; padding: 10px 12px; border-radius: 10px; background: linear-gradient(135deg, var(--color-secondary-cream), #FFE5D0); color: #6B5544; font-size: 11px; line-height: 1.6; }
.bottom-space { height: 20px; }
