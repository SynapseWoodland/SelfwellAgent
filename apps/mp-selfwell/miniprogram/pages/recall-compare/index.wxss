.recall {
  min-height: 100vh;
  padding: 32rpx;
  background-color: #FAFBFC;
}

.recall-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 24rpx;
}

.recall-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.recall-day {
  font-size: 32rpx;
  font-weight: 500;
  color: #A8C5B5;
  margin-bottom: 12rpx;
}

.recall-highlight {
  font-size: 28rpx;
  color: #4A5568;
  line-height: 1.8;
}