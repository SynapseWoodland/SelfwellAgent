/* recall-compare/index.wxss
  PR-V2-D · 对齐 15e-recall-cta-buttons.html 原型
  双时间线对比：intro-bubble + timeline-card + reply-bubble + actions-bar
*/
page { background: #FAFBFC; }

.recall-page { min-height: 100vh; background: #FAFBFC; }

/* Nav Bar */
.recall-nav {
  height: 44px;
  padding: 0 16px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FAFBFC;
  border-bottom: 1px solid #E2E8F0;
}
.nav-back { font-size: 28px; }
.nav-title { font-size: 17px; font-weight: 500; color: #2D3436; }
.nav-space { width: 32px; }

/* Scroll area */
.recall-scroll { flex: 1; padding: 16px; }

/* 引言气泡（15e原型） */
.intro-bubble {
  background: #fff;
  border-radius: 16px;
  border-top-left-radius: 4px;
  padding: 14px 16px;
  font-size: 14px;
  line-height: 1.7;
  color: #2D3436;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  max-width: 88%;
  margin-bottom: 14px;
}
.intro-label { font-size: 12px; color: #718096; margin-bottom: 6px; }
.intro-quote {
  font-style: normal;
  background: #FFF8E7;
  padding: 0 4px;
  border-radius: 3px;
  color: #A0724F;
}

/* 时间线卡片（15e原型） */
.timeline-card {
  background: #fff;
  border-radius: 16px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  margin-bottom: 14px;
}
.tl-day {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: #5A8270;
  font-weight: 500;
  margin-bottom: 4px;
}
.tl-day-icon { font-size: 14px; }
.tl-day-label {}
.tl-date { font-size: 11px; color: #A0AEC0; margin-bottom: 12px; }

/* 照片网格（双图并排） */
.tl-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 12px;
}
.tl-img {
  aspect-ratio: 1;
  background: #F5E6D3;
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  position: relative;
}
.tl-img.current-img { background: #E0F0E5; }
.tl-img-ph { font-size: 32px; opacity: 0.4; }
.tl-img-real { position: absolute; inset: 0; width: 100%; height: 100%; }
.tl-img-label {
  position: absolute;
  bottom: 6px;
  left: 8px;
  font-size: 10px;
  background: rgba(255,255,255,0.85);
  padding: 1px 6px;
  border-radius: 4px;
  color: #5A8270;
}
.tl-note {
  font-size: 13px;
  color: #4A5568;
  line-height: 1.6;
  margin-top: 8px;
}

/* AI 鼓励回复气泡（15e原型：暖色渐变） */
.reply-bubble {
  background: linear-gradient(135deg, #F5E6D3, #FFE5D0);
  border-radius: 16px;
  border-top-left-radius: 4px;
  padding: 14px 16px;
  font-size: 14px;
  line-height: 1.7;
  color: #6B5544;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  max-width: 88%;
  margin-bottom: 14px;
}
.reply-bubble em {
  font-style: normal;
  font-weight: 500;
  color: #5A8270;
}

/* 软提示语 */
.soft-tip {
  text-align: center;
  font-size: 12px;
  color: #718096;
  margin-bottom: 14px;
}

/* 空态 */
.empty-state {
  text-align: center;
  padding: 40px 20px;
}
.empty-icon { font-size: 48px; opacity: 0.4; margin-bottom: 12px; }
.empty-title { font-size: 16px; font-weight: 500; color: #2D3436; margin-bottom: 6px; }
.empty-sub { font-size: 13px; color: #718096; line-height: 1.6; }

/* 底部双 CTA（15e原型） */
.actions-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-top: 1px solid #E2E8F0;
  padding: 12px 16px 20px;
  display: flex;
  gap: 10px;
}
.btn {
  flex: 1;
  padding: 12px;
  border-radius: 24px;
  border: none;
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
}
.btn-ghost {
  background: #fff;
  color: #2D3436;
  border: 1px solid #E2E8F0;
}
.btn-primary {
  background: #A8C5B5;
  color: #fff;
}

.recall-bottom-space { height: 80px; }
