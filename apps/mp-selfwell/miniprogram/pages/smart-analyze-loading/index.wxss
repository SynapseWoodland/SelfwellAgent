/* PR-A4：A 场景分析中页样式 */

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  min-height: 100vh;
  background-color: #FAFBFC;
}

.loading-stages {
  width: 100%;
  margin-top: 32rpx;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.loading-stage-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 0;
}

.loading-stage-row + .loading-stage-row {
  border-top: 2rpx solid #F0F2F5;
}

.loading-stage-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background-color: #E2E8F0;
  flex-shrink: 0;
}

.loading-stage-row.done .loading-stage-dot {
  background-color: #A8C5B5;
}

.loading-stage-row.doing .loading-stage-dot {
  background-color: #A8C5B5;
  animation: loading-pulse 1.2s infinite ease-in-out;
}

.loading-stage-row.finished .loading-stage-dot {
  background-color: #9DB5A0;
}

.loading-stage-text {
  flex: 1;
  font-size: 28rpx;
  color: #4A5568;
}

.loading-stage-row.done .loading-stage-text,
.loading-stage-row.finished .loading-stage-text {
  color: #2D3436;
}

@keyframes loading-pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.3); }
}

.loading-progress {
  width: 100%;
  margin-top: 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.loading-progress-bar {
  flex: 1;
  height: 12rpx;
  border-radius: 6rpx;
  background-color: #E2E8F0;
  overflow: hidden;
}

.loading-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #A8C5B5 0%, #B8D4E3 100%);
  transition: width 0.4s ease-out;
}

.loading-progress-label {
  width: 80rpx;
  text-align: right;
  font-size: 24rpx;
  color: #718096;
}

.loading-error {
  width: 100%;
  margin-top: 32rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.loading-error-text {
  font-size: 26rpx;
  color: #718096;
  margin-bottom: 16rpx;
}

.loading-retry-btn {
  background-color: #A8C5B5;
  color: #FFFFFF;
  font-size: 26rpx;
  border-radius: 28rpx;
  padding: 8rpx 32rpx;
}

.loading-close {
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #718096;
}
