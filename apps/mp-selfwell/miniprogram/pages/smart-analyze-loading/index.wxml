<!--
  IA-REF: docs/design/ia-and-wireframe.md §4.3 P03b 智能分析加载
  FIGMA  : docs/design/figma-pixso-spec/pages/05-butler-analyze-loading.html
-->
<view class="loading">
  <!-- 顶部 persona-bubble（thinking 态） -->
  <persona-bubble state="thinking" title="{{loadingTitle}}" />

  <!-- 4 行 stage 进度（视觉位置固定） -->
  <view class="loading-stages">
    <view wx:for="{{stages}}" wx:key="key" class="loading-stage-row {{item.state}}">
      <view class="loading-stage-dot"></view>
      <view class="loading-stage-text">{{item.text}}</view>
    </view>
  </view>

  <!-- 渐变进度条 + percent 标签 -->
  <view class="loading-progress">
    <view class="loading-progress-bar">
      <view class="loading-progress-fill" style="width: {{percent}}%;"></view>
    </view>
    <view class="loading-progress-label">{{percent}}%</view>
  </view>

  <!-- 错误态：toast + 重试入口 -->
  <view class="loading-error" wx:if="{{errorText}}">
    <view class="loading-error-text">{{errorText}}</view>
    <button class="loading-retry-btn" bindtap="onTapRetry">{{retryLabel}}</button>
  </view>

  <!-- 底部「可关闭」小字 -->
  <view class="loading-close">
    <navigator open-type="navigateBack" hover-class="none">{{closeHint}}</navigator>
  </view>
</view>
