.report {
  min-height: 100vh;
  padding: 32rpx;
  background-color: #FAFBFC;
}

.report-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.report-card-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.report-improvement {
  font-size: 28rpx;
  color: #4A5568;
  line-height: 1.8;
}

.report-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.report-tag {
  padding: 8rpx 24rpx;
  background-color: #F5E6D3;
  color: #4A5568;
  font-size: 26rpx;
  border-radius: 16rpx;
}

.report-btn {
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  margin-top: 32rpx;
}

.report-btn--primary {
  background-color: #A8C5B5;
  color: #FFFFFF;
}

.report-btn--ghost {
  background-color: #FFFFFF;
  color: #4A5568;
  border: 2rpx solid #E2E8F0;
}