/* PR-5 · about 子页 */

.ab-page {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding: 32rpx 32rpx 200rpx;
}

.ab-hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 64rpx 32rpx 48rpx;
}

.ab-logo {
  width: 144rpx;
  height: 144rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #A8C5B5 0%, #B8D4E3 100%);
  color: #FFFFFF;
  font-size: 64rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
}

.ab-app-name {
  font-size: 40rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 8rpx;
}

.ab-slogan {
  font-size: 26rpx;
  color: #718096;
}

.ab-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.ab-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F0F2F5;
}

.ab-row:last-child {
  border-bottom: none;
}

.ab-row-label {
  font-size: 28rpx;
  color: #4A5568;
}

.ab-row-value {
  font-size: 28rpx;
  color: #2D3436;
}

.ab-row-btn {
  font-size: 26rpx;
  color: #A8C5B5;
  padding: 8rpx 24rpx;
  border: 2rpx solid #A8C5B5;
  border-radius: 16rpx;
}

.ab-thanks-title {
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
  margin-bottom: 16rpx;
}

.ab-thanks-body {
  font-size: 26rpx;
  color: #4A5568;
  line-height: 1.8;
}

.ab-footer {
  text-align: center;
  margin-top: 48rpx;
  font-size: 22rpx;
  color: #A0AEC0;
  line-height: 1.8;
}

.ab-footer-link {
  display: inline-block;
  margin-top: 8rpx;
  color: #5A8270;
  text-decoration: underline;
}