.profile {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding: 32rpx;
}

.profile-header {
  text-align: center;
  margin-bottom: 24rpx;
}

.profile-avatar {
  width: 128rpx;
  height: 128rpx;
  margin: 0 auto;
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 56rpx;
  font-weight: 500;
}

.profile-nickname {
  margin-top: 16rpx;
  font-size: 32rpx;
  color: #2D3436;
  font-weight: 500;
}

.profile-streak {
  margin-top: 8rpx;
  font-size: 26rpx;
  color: #718096;
}

.profile-progress {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.profile-progress-hint {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: #A8C5B5;
}

.profile-list {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 0 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.profile-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  border-bottom: 2rpx solid #E2E8F0;
}

.profile-row:last-child {
  border-bottom: none;
}

.profile-row-label {
  font-size: 30rpx;
  color: #2D3436;
}

.profile-row-arrow {
  font-size: 32rpx;
  color: #A0AEC0;
}

/* ─────────── PR5 FR-3：6 字段档案表单样式 ─────────── */

.profile-form {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.profile-form-banner {
  background-color: #F0F7F2;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.profile-form-banner-text {
  font-size: 26rpx;
  color: #5A8C6E;
  font-weight: 500;
}

.profile-field {
  margin-bottom: 24rpx;
}

.profile-field-label {
  font-size: 28rpx;
  color: #2D3436;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.profile-required {
  color: #E53E3E;
  margin-left: 4rpx;
}

.profile-field-input {
  border: 2rpx solid #E2E8F0;
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAFBFC;
}

.profile-field-options {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

/* chip 选中态：用 class 拼接 .profile-chip-selected，避免 [data-value='中文'] 在 wxss 编译器被替换 */
.profile-chip {
  padding: 12rpx 24rpx;
  border: 2rpx solid #E2E8F0;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4A5568;
  background-color: #FAFBFC;
}

.profile-chip-selected {
  background-color: #A8C5B5;
  border-color: #A8C5B5;
  color: #FFFFFF;
}

.profile-submit-btn {
  margin-top: 16rpx;
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 16rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
}

.profile-submit-btn::after {
  border: none;
}