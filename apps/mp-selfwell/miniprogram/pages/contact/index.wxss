/* PR-5 · contact 子页 */

.ct-page {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding: 32rpx 32rpx 200rpx;
}

.ct-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.ct-channel {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 2rpx solid #F0F2F5;
}

.ct-channel:last-child {
  border-bottom: none;
}

.ct-channel-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #FFFFFF;
  margin-right: 24rpx;
}

.ct-channel-icon-email {
  background-color: #A8C5B5;
}

.ct-channel-icon-wechat {
  background-color: #9DB5A0;
}

.ct-channel-main {
  flex: 1;
  min-width: 0;
}

.ct-channel-label {
  font-size: 24rpx;
  color: #718096;
  margin-bottom: 6rpx;
}

.ct-channel-value {
  font-size: 28rpx;
  color: #2D3436;
  font-weight: 500;
}

.ct-channel-hint {
  font-size: 22rpx;
  color: #A0AEC0;
  margin-top: 4rpx;
}

.ct-channel-btn {
  padding: 12rpx 24rpx;
  border: 2rpx solid #A8C5B5;
  border-radius: 16rpx;
  color: #A8C5B5;
  font-size: 24rpx;
}

.ct-qrcode-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
  text-align: center;
}

.ct-qrcode-title {
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.ct-qrcode-placeholder {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto;
  border: 4rpx dashed #E2E8F0;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #A0AEC0;
}

.ct-qrcode-hint {
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #A0AEC0;
}

.ct-faq-title {
  font-size: 30rpx;
  color: #2D3436;
  font-weight: 500;
  padding: 16rpx 8rpx;
}

.ct-faq-list {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.ct-faq-row {
  padding: 24rpx 32rpx;
  border-bottom: 2rpx solid #F0F2F5;
}

.ct-faq-row:last-child {
  border-bottom: none;
}

.ct-faq-q {
  display: flex;
  align-items: center;
}

.ct-faq-q-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  background-color: #F0F7F2;
  color: #5A8C6E;
  font-size: 24rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
}

.ct-faq-q-text {
  flex: 1;
  font-size: 28rpx;
  color: #2D3436;
}

.ct-faq-a {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background-color: #FAFBFC;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #4A5568;
  line-height: 1.7;
}