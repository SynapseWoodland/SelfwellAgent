.hug {
  min-height: 100vh;
  background-color: #FAFBFC;
  padding: 64rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hug-card {
  width: 100%;
  aspect-ratio: 0.75;
  background: linear-gradient(160deg, #F5E6D3 0%, #F0D9C4 100%);
  border-radius: 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 48rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.hug-badge {
  font-size: 24rpx;
  color: #4A5568;
  letter-spacing: 4rpx;
  margin-bottom: 16rpx;
}

.hug-title {
  font-size: 56rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1.3;
}

.hug-sub {
  margin-top: 24rpx;
  font-size: 30rpx;
  color: #4A5568;
}

.hug-emoji {
  margin-top: 48rpx;
  font-size: 128rpx;
  line-height: 1;
}

.hug-btn {
  margin-top: 64rpx;
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
  width: 100%;
}