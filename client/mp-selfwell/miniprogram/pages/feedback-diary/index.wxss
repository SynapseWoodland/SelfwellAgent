.diary {
  min-height: 100vh;
  padding: 32rpx;
  background-color: #FAFBFC;
}

.diary-card {
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.diary-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #2D3436;
  margin-bottom: 16rpx;
}

.diary-input {
  width: 100%;
  height: 320rpx;
  font-size: 28rpx;
  color: #2D3436;
  background-color: #FAFBFC;
  border-radius: 16rpx;
  padding: 16rpx;
  box-sizing: border-box;
}

.diary-btn {
  margin-top: 24rpx;
  background-color: #A8C5B5;
  color: #FFFFFF;
  border-radius: 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}

.diary-ack-wrap {
  margin-top: 32rpx;
  padding: 16rpx;
}

.diary-ack-tip {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #A0AEC0;
  padding-left: 16rpx;
}