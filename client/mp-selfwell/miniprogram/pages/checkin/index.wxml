<view class="checkin">
  <view class="checkin-title">今日已完成</view>
  <view class="checkin-items">
    <view
      wx:for="{{todayItems}}"
      wx:key="id"
      class="checkin-item"
    >
      <view class="checkin-tick">✓</view>
      <view class="checkin-item-title">{{item.title}}</view>
    </view>
  </view>

  <view class="checkin-feedback">
    <view class="checkin-feedback-title">今天有什么想记录的？</view>
    <textarea
      class="checkin-feedback-input"
      placeholder="一句话也可以，没有也没关系"
      maxlength="200"
      value="{{text}}"
      bindinput="onInput"
    />
    <view class="checkin-feedback-count">{{text.length}} / 200</view>
  </view>

  <button
    class="checkin-btn"
    bindtap="onSubmit"
    loading="{{submitting}}"
    disabled="{{submitting}}"
  >
    完成打卡
  </button>
</view>