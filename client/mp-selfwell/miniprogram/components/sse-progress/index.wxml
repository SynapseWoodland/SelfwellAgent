<view class="sse-progress">
  <view
    wx:for="{{stages}}"
    wx:key="key"
    class="stage {{index <= currentIndex ? 'is-active' : ''}} {{index === currentIndex ? 'is-current' : ''}}"
  >
    <view class="stage-dot"></view>
    <view class="stage-label">{{item.label}}</view>
  </view>
</view>
<view wx:if="{{errorText}}" class="sse-error">{{errorText}}</view>