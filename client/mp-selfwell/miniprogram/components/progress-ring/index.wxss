.ring-wrap {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.ring-svg {
  transform: rotate(-90deg);
}

.ring-bg {
  fill: none;
  stroke: #E2E8F0;
}

.ring-fg {
  fill: none;
  stroke: #A8C5B5;
  transition: stroke-dashoffset 480ms cubic-bezier(0.16, 1, 0.3, 1);
}

.ring-text {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.ring-label {
  font-size: 56rpx;
  font-weight: 600;
  color: #2D3436;
  line-height: 1;
}

.ring-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #718096;
}