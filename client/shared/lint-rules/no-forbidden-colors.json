{
  "$id": "no-forbidden-colors",
  "$schema": "https://schemas.openpolicyagent.org/manifest/v1",
  "description": "Reusable forbidden-hex scan for client/ + backend/. Reads forbidden list from `client/shared/lint-rules/forbidden-colors.json` so the rule stays single-source.",
  "forbiddenHex": [
    "#FF4D4F",
    "#D32F2F",
    "#007BFF"
  ],
  "rationale": "Pixel-level禁色 — see docs/plan/mvp-implementation-plan.md §17 #11",
  "appliesTo": [
    "client/flutter_app/lib/**/*.dart",
    "client/mp-selfwell/**/*.{ts,wxml,wxss,json}",
    "backend/app/**/*.py"
  ],
  "ciCommand": {
    "bash": "client/flutter_app/scripts/check_forbidden_colors.sh",
    "pwsh": "pwsh -File client/flutter_app/scripts/check_forbidden_colors.ps1"
  }
}